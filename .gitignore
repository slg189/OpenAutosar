# ===== Build artifacts =====
# 编译临时目标文件 (保留目录占位 README)
Projects/*/Obj/*
!Projects/*/Obj/README.md
**/Obj/*.o
**/Obj/*.d
# 目标文件/依赖文件 (源码模块按约定就地编译时也会产生)
**/*.o
**/*.d

# 链接输出 (hex / elf / map) — 保留目录占位 README
Projects/*/Out/*
!Projects/*/Out/README.md
**/*.hex
**/*.elf
**/*.map
**/*.lst

# 生成的配置代码 (由 EB / ETAS 工具生成) — 保留目录占位 README
Projects/*/Gen/MCAL/*
Projects/*/Gen/CDD/*
Projects/*/Gen/BSW/*
Projects/*/Gen/Vector/*
!Projects/*/Gen/MCAL/README.md
!Projects/*/Gen/CDD/README.md
!Projects/*/Gen/BSW/README.md

# 编译生成的库 (.a 由各模块构建产出)
Projects/*/Libs/ASW/*.a
Projects/*/Libs/BSW/*.a
Projects/*/Libs/CDD/*.a
Projects/*/Libs/MCAL/*.a

# ===== Test / coverage outputs =====
build_test/
coverage_output/
Projects/*/Reports/*.xml
Projects/*/Reports/*.html
Projects/*/Reports/static_check/
Projects/*/Reports/check_dashboard_config.json
Projects/*/Reports/parasoft/
Projects/*/parasoft.json.bak
Projects/*/vector_codegen.json.bak
!Projects/*/Reports/.gitkeep
log_repo

# ===== SCons =====
.sconsign.dblite
.sconf_temp/
config.log

# ===== v2 构建框架产物 (YAML 驱动) =====
# 自动生成的 API 文档 / 编译数据库 / 代码生成 stamp
Projects/*/Docs/api/
**/compile_commands.json
**/.*.stamp

# ===== Editor / OS =====
.vscode/
.idea/
*.swp
*~
.DS_Store
Thumbs.db

# ===== Python =====
__pycache__/
*.pyc

# ===== Sub-repo staging =====
.subrepos/

# ===== cppcheck (scons check) =====
build_check/
**/*.ctu-info
**/cppcheck-addon-ctu-file-list*

# ===== 隔离的构建 venv (Tools/setup_env.py) =====
Tools/.venv/

# ===== 下载固定的工具 (Tools/fetch_tools.py) =====
Tools/.toolcache/

# ===== Offline package artifacts =====
Tools/OpenAutosar_Offline_Tools_Windows_x64.zip
Tools/Offline_Tools_Windows_x64/_joined_OpenAutosar_Offline_Tools_Windows_x64.zip
