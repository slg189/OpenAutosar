# SConscript - 集成层 (Integration)
# 基础工程师维护的集成/胶水代码, 编译为工程私有目标并参与最终链接。
Import('env')
# ASW/CDD/BSW 库直接位于 <Layer>_Libs/ 下 (项目身份在子库名中, 拉取时已确定项目)
env.Append(CPPPATH=[
    Dir('inc'),
    '#ASW_Libs/inc', '#ASW_Libs/VehicleControl/inc', '#ASW_Libs/EnergyManagement/inc',
    '#CDD_Libs/CddPwm/inc',
    '#BSW_Libs/inc', '#BSW_Libs/Os/inc', '#BSW_Libs/Com/inc',
    '#Components/Common/inc', '#Components/Mcu/Sbm/inc',
    '#MCAL_Libs/inc',
])
objs = env.Object(Glob('src/*.c'))
Return('objs')
