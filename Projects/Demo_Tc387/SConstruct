# ============================================================================
# SConstruct - OpenAutosar 工程构建入口 (Project: Demo_Tc387)
#
# 「灵活配置 / 灵活编译」: 模块的 source/lib 形态、启用与编译选项均由
# module_config.py 声明, 并可经命令行覆盖:
#   scons                         # 按 module_config.py 构建
#   scons variant=Debug           # 切换 Debug/Release
#   scons chip=Tc367              # 切换目标芯片
#   scons only=Adc,CddPwm         # 仅编译指定模块
#   scons skip=EnergyManagement   # 跳过指定模块
#   scons layers=ASW,MCAL         # 仅编译指定层
#
# 信息安全: source 模式需源码可见; 不可见的层以 *_Libs/*.a 形式链接。
# ============================================================================
import os, sys

# ---- 载入工程配置与公共构建辅助 ----
sys.path.insert(0, Dir('#Tools/Scons').abspath)
import build_helpers as bh           # noqa: E402
import module_config as mc           # noqa: E402

opts = bh.parse_cli(ARGUMENTS, {'VARIANT': mc.VARIANT, 'CHIP': mc.CHIP})
VARIANT = opts['variant']
CHIP    = opts['chip']
MCU     = CHIP.lower().replace('tc', 'tc')   # Tc387 -> tc387
PROJECT = mc.PROJECT

print('[build] project=%s chip=%s variant=%s' % (PROJECT, CHIP, VARIANT))

# ---- 基础环境 (TASKING / GCC for TriCore) ----
base_env = Environment(
    ENV       = os.environ,
    CC        = os.environ.get('TRICORE_CC', 'tricore-gcc'),
    AR        = os.environ.get('TRICORE_AR', 'tricore-ar'),
    CCFLAGS   = mc.GLOBAL_CFLAGS[VARIANT] + ['-Wall', '-mcpu=%s' % MCU],
    CPPDEFINES = list(mc.GLOBAL_DEFINES),
    OBJPREFIX = '',
)

# 公共头文件 (始终可见的公共类型/抽象)
base_env.Append(CPPPATH=[
    '#Components/Common/inc',
    '#MCAL_Libs/inc',
])
Export({'env': base_env})

source_libs = []     # 本次从源码编译产出的 .a
prebuilt_libs = []   # mode=lib 直接链接的已释放 .a
release_actions = [] # 源码模块编译后回灌 *_Libs 的安装动作

# ---- 遍历模块配置, 按 source/lib 灵活处理 ----
for layer, modules in mc.MODULES.items():
    for name, cfg in modules.items():
        if not bh.is_selected(layer, name, cfg, opts):
            print('[build]   skip %-5s %s' % (layer, name))
            continue

        mode = cfg.get('mode', 'lib')

        if mode == 'source':
            src_dir = bh.source_dir(layer, name, CHIP)
            sconscript = '%s/SConscript' % src_dir
            if not os.path.exists(File(sconscript).abspath):
                print('[build]   WARN 源码不可见, 回退 lib: %s/%s' % (layer, name))
                mode = 'lib'
            else:
                # 模块级编译选项: 克隆环境并追加 cflags/defines, 实现按模块灵活编译
                menv = base_env.Clone()
                menv.Append(CCFLAGS=cfg.get('cflags', []))
                menv.Append(CPPDEFINES=cfg.get('defines', []))
                Export({'env': menv})
                vdir = os.path.join('Obj', layer, name)
                lib = SConscript(sconscript, variant_dir=vdir, duplicate=0)
                source_libs += lib
                # 安装到工程 Libs/ 并释放到根 *_Libs (供下游二进制集成)
                base_env.Install('Libs/%s' % layer, lib)
                release_actions += base_env.Install(
                    os.path.dirname(File(bh.lib_file(layer, name, CHIP)).abspath), lib)
                print('[build]   src  %-5s %s  cflags+=%s' % (layer, name, cfg.get('cflags', [])))

        if mode == 'lib':
            la = File(bh.lib_file(layer, name, CHIP))
            prebuilt_libs.append(la)
            base_env.Append(CPPPATH=bh.lib_incdirs(layer, name, CHIP))
            print('[build]   lib  %-5s %s  <- %s' % (layer, name, la.path))

# ---- Components (公共/启动) 始终源码编译 ----
for comp in ['#Components/Common/SConscript', '#Components/Mcu/Sbm/SConscript']:
    Export({'env': base_env})
    source_libs += SConscript(
        comp, variant_dir=os.path.join('Obj', 'CMP', os.path.basename(os.path.dirname(comp))),
        duplicate=0)

# ---- 集成层 (Integration): 基础工程师维护的胶水代码 ----
Export({'env': base_env})
integration_objs = SConscript('Integration/SConscript',
                              variant_dir=os.path.join('Obj', 'Integration'), duplicate=0)

# ---- 链接 ----
linker_script = File('Ld/%s.ld' % PROJECT)
link_env = base_env.Clone()
link_env.Append(LINKFLAGS=['-T', linker_script.abspath,
                           '-Wl,-Map=Out/%s.map' % PROJECT])

elf = link_env.Program(
    target = 'Out/%s.elf' % PROJECT,
    source = (integration_objs
              + Glob('Gen/MCAL/*.c') + Glob('Gen/CDD/*.c') + Glob('Gen/BSW/*.c')
              + source_libs + prebuilt_libs),
)
Depends(elf, linker_script)

hex_out = link_env.Command('Out/%s.hex' % PROJECT, elf,
                           'tricore-objcopy -O ihex $SOURCE $TARGET')

# 别名: 编译同时把源码模块释放回 *_Libs
Alias('release', release_actions)
Default(hex_out)
