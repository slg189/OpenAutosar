<?xml version="1.0" encoding="UTF-8"?>
<AUTOSAR xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://autosar.org/schema/r4.0"
    xsi:schemaLocation="http://autosar.org/schema/r4.0 AUTOSAR_4-2-2.xsd">
  <AR-PACKAGES>
    <AR-PACKAGE>
      <SHORT-NAME>AUTOSAR_DoIP</SHORT-NAME>
      <AR-PACKAGES>
        <AR-PACKAGE>
          <SHORT-NAME>BswModuleEntrys</SHORT-NAME>
          <ELEMENTS>
            <BSW-MODULE-ENTRY>
              <SHORT-NAME>DoIP_GetVersionInfo</SHORT-NAME>
              <LONG-NAME>
                <L-4 L="EN">DoIP_GetVersionInfo</L-4>
              </LONG-NAME>
              <DESC>
                <L-2 L="EN">Returns the version information of this module.</L-2>
              </DESC>
            </BSW-MODULE-ENTRY>
            <BSW-MODULE-ENTRY>
              <SHORT-NAME>DoIP_IfCancelTransmit</SHORT-NAME>
              <LONG-NAME>
                <L-4 L="EN">DoIP_IfCancelTransmit</L-4>
              </LONG-NAME>
              <DESC>
                <L-2 L="EN">Requests cancellation of an ongoing transmission of an I-PDU in a lower layer communication interface module.</L-2>
              </DESC>
            </BSW-MODULE-ENTRY>
            <BSW-MODULE-ENTRY>
              <SHORT-NAME>DoIP_IfTransmit</SHORT-NAME>
              <LONG-NAME>
                <L-4 L="EN">DoIP_IfTransmit</L-4>
              </LONG-NAME>
              <DESC>
                <L-2 L="EN">Requests transmission of an I-PDU.</L-2>
              </DESC>
            </BSW-MODULE-ENTRY>
            <BSW-MODULE-ENTRY>
              <SHORT-NAME>DoIP_Init</SHORT-NAME>
              <LONG-NAME>
                <L-4 L="EN">DoIP_Init</L-4>
              </LONG-NAME>
              <DESC>
                <L-2 L="EN">This service initializes all global variables of the DoIP module. After return of this service the DoIP module is operational.</L-2>
              </DESC>
            </BSW-MODULE-ENTRY>
            <BSW-MODULE-ENTRY>
              <SHORT-NAME>DoIP_LocalIpAddrAssignmentChg</SHORT-NAME>
              <LONG-NAME>
                <L-4 L="EN">DoIP_LocalIpAddrAssignmentChg</L-4>
              </LONG-NAME>
              <DESC>
                <L-2 L="EN">This function gets called by the SoAd if an IP address assignment related to a socket connection changes (i.e. new address assigned or assigned address becomes invalid).</L-2>
              </DESC>
            </BSW-MODULE-ENTRY>
            <BSW-MODULE-ENTRY>
              <SHORT-NAME>DoIP_MainFunction</SHORT-NAME>
              <LONG-NAME>
                <L-4 L="EN">DoIP_MainFunction</L-4>
              </LONG-NAME>
              <DESC>
                <L-2 L="EN">Schedules the Diagnostic over IP module. (Entry point for scheduling)</L-2>
              </DESC>
              <IS-REENTRANT>false</IS-REENTRANT>
              <IS-SYNCHRONOUS>true</IS-SYNCHRONOUS>
              <CALL-TYPE>SCHEDULED</CALL-TYPE>
              <EXECUTION-CONTEXT>TASK</EXECUTION-CONTEXT>
              <SW-SERVICE-IMPL-POLICY>STANDARD</SW-SERVICE-IMPL-POLICY>
            </BSW-MODULE-ENTRY>
            <BSW-MODULE-ENTRY>
              <SHORT-NAME>DoIP_SoAdIfRxIndication</SHORT-NAME>
              <LONG-NAME>
                <L-4 L="EN">DoIP_SoAdIfRxIndication</L-4>
              </LONG-NAME>
              <DESC>
                <L-2 L="EN">Indication of a received I-PDU from a lower layer communication interface module.</L-2>
              </DESC>
            </BSW-MODULE-ENTRY>
            <BSW-MODULE-ENTRY>
              <SHORT-NAME>DoIP_SoAdIfTxConfirmation</SHORT-NAME>
              <LONG-NAME>
                <L-4 L="EN">DoIP_SoAdIfTxConfirmation</L-4>
              </LONG-NAME>
              <DESC>
                <L-2 L="EN">The lower layer communication interface module confirms the transmission of an I-PDU.</L-2>
              </DESC>
            </BSW-MODULE-ENTRY>
            <BSW-MODULE-ENTRY>
              <SHORT-NAME>DoIP_SoAdTpCopyRxData</SHORT-NAME>
              <LONG-NAME>
                <L-4 L="EN">DoIP_SoAdTpCopyRxData</L-4>
              </LONG-NAME>
              <DESC>
                <L-2 L="EN">This function is called to provide the received data of an I-PDU segment (N-PDU) to the upper layer. Each call to this function provides the next part of the I-PDU data. The size of the remaining data is written to the position indicated by bufferSizePtr.</L-2>
              </DESC>
            </BSW-MODULE-ENTRY>
            <BSW-MODULE-ENTRY>
              <SHORT-NAME>DoIP_SoAdTpCopyTxData</SHORT-NAME>
              <LONG-NAME>
                <L-4 L="EN">DoIP_SoAdTpCopyTxData</L-4>
              </LONG-NAME>
              <DESC>
                <L-2 L="EN">This function is called to acquire the transmit data of an I-PDU segment (N-PDU). Each call to this function provides the next part of the I-PDU data unless retry->TpDataState is TP_DATARETRY. In this case the function restarts to copy the data beginning at the offset from the current position indicated by retry->TxTpDataCnt. The size of the remaining data is written to the position indicated by availableDataPtr.</L-2>
              </DESC>
            </BSW-MODULE-ENTRY>
            <BSW-MODULE-ENTRY>
              <SHORT-NAME>DoIP_SoAdTpRxIndication</SHORT-NAME>
              <LONG-NAME>
                <L-4 L="EN">DoIP_SoAdTpRxIndication</L-4>
              </LONG-NAME>
              <DESC>
                <L-2 L="EN">Called after an I-PDU has been received via the TP API, the result indicates whether the transmission was successful or not.</L-2>
              </DESC>
            </BSW-MODULE-ENTRY>
            <BSW-MODULE-ENTRY>
              <SHORT-NAME>DoIP_SoAdTpStartOfReception</SHORT-NAME>
              <LONG-NAME>
                <L-4 L="EN">DoIP_SoAdTpStartOfReception</L-4>
              </LONG-NAME>
              <DESC>
                <L-2 L="EN">This function is called at the start of receiving an N-SDU. The N-SDU might be fragmented into multiple N-PDUs (FF with one or more following CFs) or might consist of a single N-PDU (SF).</L-2>
              </DESC>
            </BSW-MODULE-ENTRY>
            <BSW-MODULE-ENTRY>
              <SHORT-NAME>DoIP_SoAdTpTxConfirmation</SHORT-NAME>
              <LONG-NAME>
                <L-4 L="EN">DoIP_SoAdTpTxConfirmation</L-4>
              </LONG-NAME>
              <DESC>
                <L-2 L="EN">This function is called after the I-PDU has been transmitted on its network, the result indicates whether the transmission was successful or not.</L-2>
              </DESC>
            </BSW-MODULE-ENTRY>
            <BSW-MODULE-ENTRY>
              <SHORT-NAME>DoIP_SoConModeChg</SHORT-NAME>
              <LONG-NAME>
                <L-4 L="EN">DoIP_SoConModeChg</L-4>
              </LONG-NAME>
              <DESC>
                <L-2 L="EN">Notification about a SoAd socket connection state change, e.g. socket connection gets online</L-2>
              </DESC>
            </BSW-MODULE-ENTRY>
            <BSW-MODULE-ENTRY>
              <SHORT-NAME>DoIP_TpCancelReceive</SHORT-NAME>
              <LONG-NAME>
                <L-4 L="EN">DoIP_TpCancelReceive</L-4>
              </LONG-NAME>
              <DESC>
                <L-2 L="EN">By calling this API with the corresponding DoIPPduRRxId the currently ongoing data reception is terminated immediately. When the function returns, no reception is in progress anymore with the given DoIPPduRRxId identifier.</L-2>
              </DESC>
            </BSW-MODULE-ENTRY>
            <BSW-MODULE-ENTRY>
              <SHORT-NAME>DoIP_TpCancelTransmit</SHORT-NAME>
              <LONG-NAME>
                <L-4 L="EN">DoIP_TpCancelTransmit</L-4>
              </LONG-NAME>
              <DESC>
                <L-2 L="EN">This service primitive is used to cancel the transfer of pending DoIPPduRTxIds. The connection is identified by DoIPPduRTxId. When the function returns, no transmission is in progress anymore with the given DoIPPduRTxId identifier.</L-2>
              </DESC>
            </BSW-MODULE-ENTRY>
            <BSW-MODULE-ENTRY>
              <SHORT-NAME>DoIP_TpTransmit</SHORT-NAME>
              <LONG-NAME>
                <L-4 L="EN">DoIP_TpTransmit</L-4>
              </LONG-NAME>
              <DESC>
                <L-2 L="EN">This service is called to request the transfer data from the PduRouter to the SoAd. It is used to indicate the transmission which will be performed in the DoIP_Mainfunction.</L-2>
              </DESC>
              <INTRODUCTION>
                <P>
                  <L-1 L="EN">Within the provided DoIPPduRTxInfoPtr only SduLength is valid (no data)!If this function returns E_OK then the DoIP module will raise a subsequent call to PduR_DoIPCopyTxData in order to get the data to send.</L-1>
                </P>
              </INTRODUCTION>
            </BSW-MODULE-ENTRY>
          </ELEMENTS>
        </AR-PACKAGE>
        <AR-PACKAGE>
          <SHORT-NAME>BswModuleDescriptions</SHORT-NAME>
          <ELEMENTS>
            <BSW-MODULE-DESCRIPTION>
              <SHORT-NAME>DoIP</SHORT-NAME>
              <CATEGORY>BSW_MODULE</CATEGORY>
              <MODULE-ID>173</MODULE-ID>
              <PROVIDED-ENTRYS>
                <BSW-MODULE-ENTRY-REF-CONDITIONAL>
                  <BSW-MODULE-ENTRY-REF DEST="BSW-MODULE-ENTRY">/AUTOSAR_DoIP/BswModuleEntrys/DoIP_MainFunction</BSW-MODULE-ENTRY-REF>
                </BSW-MODULE-ENTRY-REF-CONDITIONAL>
              </PROVIDED-ENTRYS>
              <INTERNAL-BEHAVIORS>
                <BSW-INTERNAL-BEHAVIOR>
                  <SHORT-NAME>IB_DoIP</SHORT-NAME>
                  <ENTITYS>
                    <BSW-SCHEDULABLE-ENTITY>
                      <SHORT-NAME>BSWSE_DoIPMainFunction</SHORT-NAME>
                      <IMPLEMENTED-ENTRY-REF DEST="BSW-MODULE-ENTRY">/AUTOSAR_DoIP/BswModuleEntrys/DoIP_MainFunction</IMPLEMENTED-ENTRY-REF>
                    </BSW-SCHEDULABLE-ENTITY>
                  </ENTITYS>
                </BSW-INTERNAL-BEHAVIOR>
              </INTERNAL-BEHAVIORS>
            </BSW-MODULE-DESCRIPTION>
          </ELEMENTS>
        </AR-PACKAGE>
        <AR-PACKAGE>
          <SHORT-NAME>BswImplementations</SHORT-NAME>
          <ELEMENTS>
            <BSW-IMPLEMENTATION>
              <SHORT-NAME>DoIP</SHORT-NAME>
              <CODE-DESCRIPTORS>
                <CODE>
                  <SHORT-NAME>CodeDescriptor</SHORT-NAME>
                  <ARTIFACT-DESCRIPTORS>
                    <AUTOSAR-ENGINEERING-OBJECT>
                      <SHORT-LABEL>ArEngObject</SHORT-LABEL>
                      <CATEGORY>SWSRC</CATEGORY>
                    </AUTOSAR-ENGINEERING-OBJECT>
                  </ARTIFACT-DESCRIPTORS>
                </CODE>
              </CODE-DESCRIPTORS>
              <PROGRAMMING-LANGUAGE>C</PROGRAMMING-LANGUAGE>
              <RESOURCE-CONSUMPTION>
                <SHORT-NAME>DoIP_ResourceConsumption</SHORT-NAME>
                <MEMORY-SECTIONS>
                  <MEMORY-SECTION>
                    <SHORT-NAME>DOIP_VAR_CLEARED</SHORT-NAME>
                    <PREFIX-REF DEST="SECTION-NAME-PREFIX">/AUTOSAR_DoIP/BswImplementations/DoIP/DoIP_ResourceConsumption/DOIP</PREFIX-REF>
                    <SW-ADDRMETHOD-REF DEST="SW-ADDR-METHOD">/RB/RBA/Common/CentralElements/SwAddrMethods/VAR_CLEARED</SW-ADDRMETHOD-REF>
                    <SYMBOL>VAR_CLEARED</SYMBOL>
                  </MEMORY-SECTION>
                  <MEMORY-SECTION>
                    <SHORT-NAME>DOIP_VAR_INIT</SHORT-NAME>
                    <PREFIX-REF DEST="SECTION-NAME-PREFIX">/AUTOSAR_DoIP/BswImplementations/DoIP/DoIP_ResourceConsumption/DOIP</PREFIX-REF>
                    <SW-ADDRMETHOD-REF DEST="SW-ADDR-METHOD">/RB/RBA/Common/CentralElements/SwAddrMethods/VAR_INIT</SW-ADDRMETHOD-REF>
                    <SYMBOL>VAR_INIT</SYMBOL>
                  </MEMORY-SECTION>
                  <MEMORY-SECTION>
                    <SHORT-NAME>DOIP_CONST</SHORT-NAME>
                    <PREFIX-REF DEST="SECTION-NAME-PREFIX">/AUTOSAR_DoIP/BswImplementations/DoIP/DoIP_ResourceConsumption/DOIP</PREFIX-REF>
                    <SW-ADDRMETHOD-REF DEST="SW-ADDR-METHOD">/RB/RBA/Common/CentralElements/SwAddrMethods/CONST</SW-ADDRMETHOD-REF>
                    <SYMBOL>CONST</SYMBOL>
                  </MEMORY-SECTION>
                  <MEMORY-SECTION>
                    <SHORT-NAME>DOIP_CODE</SHORT-NAME>
                    <PREFIX-REF DEST="SECTION-NAME-PREFIX">/AUTOSAR_DoIP/BswImplementations/DoIP/DoIP_ResourceConsumption/DOIP</PREFIX-REF>
                    <SW-ADDRMETHOD-REF DEST="SW-ADDR-METHOD">/RB/RBA/Common/CentralElements/SwAddrMethods/CODE</SW-ADDRMETHOD-REF>
                    <SYMBOL>CODE</SYMBOL>
                  </MEMORY-SECTION>
                  <MEMORY-SECTION>
                    <SHORT-NAME>DoIP_CODE</SHORT-NAME>
                    <PREFIX-REF DEST="SECTION-NAME-PREFIX">/AUTOSAR_DoIP/BswImplementations/DoIP/DoIP_ResourceConsumption/DoIP</PREFIX-REF>
                    <SW-ADDRMETHOD-REF DEST="SW-ADDR-METHOD">/RB/RBA/Common/CentralElements/SwAddrMethods/CODE</SW-ADDRMETHOD-REF>
                    <SYMBOL>CODE</SYMBOL>
                  </MEMORY-SECTION>
                  <MEMORY-SECTION>
                    <SHORT-NAME>DOIP_CONFIG_CODE_POSTBUILD</SHORT-NAME>
                    <PREFIX-REF DEST="SECTION-NAME-PREFIX">/AUTOSAR_DoIP/BswImplementations/DoIP/DoIP_ResourceConsumption/DOIP</PREFIX-REF>
                    <SW-ADDRMETHOD-REF DEST="SW-ADDR-METHOD">/RB/RBA/Common/CentralElements/SwAddrMethods/CODE</SW-ADDRMETHOD-REF>
                    <SYMBOL>CONFIG_CODE_POSTBUILD</SYMBOL>
                  </MEMORY-SECTION>
                  <MEMORY-SECTION>
                    <SHORT-NAME>DOIP_CONFIG_DATA_POSTBUILD_UNSPECIFIED</SHORT-NAME>
                    <PREFIX-REF DEST="SECTION-NAME-PREFIX">/AUTOSAR_DoIP/BswImplementations/DoIP/DoIP_ResourceConsumption/DOIP</PREFIX-REF>
                    <SW-ADDRMETHOD-REF DEST="SW-ADDR-METHOD">/RB/RBA/Common/CentralElements/SwAddrMethods/CONFIG_DATA_POSTBUILD</SW-ADDRMETHOD-REF>
                    <SYMBOL>CONFIG_DATA_POSTBUILD_UNSPECIFIED</SYMBOL>
                  </MEMORY-SECTION>
                  <MEMORY-SECTION>
                    <SHORT-NAME>DOIP_CONFIG_DATA_UNSPECIFIED</SHORT-NAME>
                    <PREFIX-REF DEST="SECTION-NAME-PREFIX">/AUTOSAR_DoIP/BswImplementations/DoIP/DoIP_ResourceConsumption/DOIP</PREFIX-REF>
                    <SW-ADDRMETHOD-REF DEST="SW-ADDR-METHOD">/RB/RBA/Common/CentralElements/SwAddrMethods/CONFIG_DATA</SW-ADDRMETHOD-REF>
                    <SYMBOL>CONFIG_DATA_UNSPECIFIED</SYMBOL>
                  </MEMORY-SECTION>
                </MEMORY-SECTIONS>
                <SECTION-NAME-PREFIXS>
                  <SECTION-NAME-PREFIX>
                    <SHORT-NAME>DOIP</SHORT-NAME>
                    <SYMBOL>DOIP</SYMBOL>
                  </SECTION-NAME-PREFIX>
                  <SECTION-NAME-PREFIX>
                    <SHORT-NAME>DoIP</SHORT-NAME>
                    <SYMBOL>DoIP</SYMBOL>
                  </SECTION-NAME-PREFIX>
                </SECTION-NAME-PREFIXS>
              </RESOURCE-CONSUMPTION>
              <SW-VERSION>9.0.0</SW-VERSION>
              <VENDOR-ID>6</VENDOR-ID>
              <AR-RELEASE-VERSION>4.2.2</AR-RELEASE-VERSION>
              <BEHAVIOR-REF DEST="BSW-INTERNAL-BEHAVIOR">/AUTOSAR_DoIP/BswModuleDescriptions/DoIP/IB_DoIP</BEHAVIOR-REF>
            </BSW-IMPLEMENTATION>
          </ELEMENTS>
        </AR-PACKAGE>
      </AR-PACKAGES>
    </AR-PACKAGE>
  </AR-PACKAGES>
</AUTOSAR>
