              <SW-SERVICE-IMPL-POLICY>STANDARD</SW-SERVICE-IMPL-POLICY>
            </BSW-MODULE-ENTRY>
            <BSW-MODULE-ENTRY>
              <SHORT-NAME>EthIf_ProvideTxBuffer</SHORT-NAME>
              <LONG-NAME>
                <L-4 L="EN">This service provides access to a transmit buffer of the specified Ethernet controller.</L-4>
              </LONG-NAME>
              <DESC>
                <L-2 L="EN">Provides access to a transmit buffer of the specified Ethernet controller. </L-2>
              </DESC>
