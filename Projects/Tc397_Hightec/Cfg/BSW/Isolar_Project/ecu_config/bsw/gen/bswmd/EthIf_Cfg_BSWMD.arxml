                      <SHORT-NAME>EV_SE_MainFunctionTx</SHORT-NAME>
                      <STARTS-ON-EVENT-REF DEST="BSW-SCHEDULABLE-ENTITY">/AUTOSAR_EthIf/BswModuleDescriptions/EthIf/BswInternalBehavior/SE_MainFunctionTx</STARTS-ON-EVENT-REF>
