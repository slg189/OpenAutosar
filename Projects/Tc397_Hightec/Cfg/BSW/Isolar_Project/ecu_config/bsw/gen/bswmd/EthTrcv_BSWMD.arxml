                    <L-4 L="EN" />
                </LONG-NAME>
                <ELEMENTS>
                    <BSW-MODULE-ENTRY>
                        <SHORT-NAME>EthTrcv_MainFunction</SHORT-NAME>
                        <LONG-NAME>
                            <L-4 L="EN"> Cyclic Main Function which is called from the scheduler</L-4>
                        </LONG-NAME>
                        <DESC>
                            <L-2 L="EN">EthTrcv stores the mode request or status from
                                EthTrcv_SetTransceiverMode() and the mode change will be executed in th
                                EthTrcv_MainFunction. Also, the link status and the mode status will be monitored.
                            </L-2>
                        </DESC> 
                        <INTRODUCTION>
                    <NOTE NOTE-TYPE="CAUTION">
                        <P>
                        <L-1 L="EN" /> 
                        </P>
                        </NOTE>
                            <P>
							<L-1 L="EN" /> 
							</P>
							</INTRODUCTION>                       
                        <IS-REENTRANT>false</IS-REENTRANT>
                        <IS-SYNCHRONOUS>true</IS-SYNCHRONOUS>
                        <CALL-TYPE>SCHEDULED</CALL-TYPE>
                        <EXECUTION-CONTEXT>TASK</EXECUTION-CONTEXT>
                        <SW-SERVICE-IMPL-POLICY>STANDARD</SW-SERVICE-IMPL-POLICY>
                    </BSW-MODULE-ENTRY>
                </ELEMENTS>
            </AR-PACKAGE>
            <AR-PACKAGE>
                <SHORT-NAME>CompuMethods</SHORT-NAME>
                <ELEMENTS>                    
