<?xml version="1.0" encoding="UTF-8"?>
<AUTOSAR xmlns="http://autosar.org/schema/r4.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://autosar.org/schema/r4.0 autosar_4-3-0.xsd">
  <AR-PACKAGES>
    <AR-PACKAGE>
      <SHORT-NAME>AUTOSAR_EthTrcv</SHORT-NAME>
      <AR-PACKAGES>
       <AR-PACKAGE>
        <SHORT-NAME>TimingExtensions</SHORT-NAME>
        <ELEMENTS>
         <BSW-MODULE-TIMING>
          <SHORT-NAME>EthTrcv</SHORT-NAME>
          <TIMING-DESCRIPTIONS>
            <TD-EVENT-BSW-INTERNAL-BEHAVIOR>
              <SHORT-NAME>EOC_T_xxms</SHORT-NAME>
              <BSW-MODULE-ENTITY-REF DEST="BSW-SCHEDULABLE-ENTITY">/AUTOSAR_EthTrcv/BswModuleDescriptions/EthTrcv/BswInternalBehavior/SE_MainFunction</BSW-MODULE-ENTITY-REF>
            </TD-EVENT-BSW-INTERNAL-BEHAVIOR>
          </TIMING-DESCRIPTIONS>
          <TIMING-REQUIREMENTS>
            <EXECUTION-ORDER-CONSTRAINT>
              <SHORT-NAME>EOC_T_xxms</SHORT-NAME>
              <EXECUTION-ORDER-CONSTRAINT-TYPE>ORDINARY-EOC</EXECUTION-ORDER-CONSTRAINT-TYPE>
              <IS-EVENT>true</IS-EVENT>
              <ORDERED-ELEMENTS>
                <EOC-EVENT-REF>
                  <SHORT-NAME>EOCEventRef_EthTrcv_1</SHORT-NAME>
                  <BSW-MODULE-INSTANCE-REF DEST="BSW-IMPLEMENTATION">/AUTOSAR_EthTrcv/BswImplementations/EthTrcv</BSW-MODULE-INSTANCE-REF>
                  <EVENT-REF DEST="BSW-TIMING-EVENT">/AUTOSAR_EthTrcv/BswModuleDescriptions/EthTrcv/BswInternalBehavior/EV_SE_MainFunction</EVENT-REF>
                </EOC-EVENT-REF>
              </ORDERED-ELEMENTS>
              <PERMIT-MULTIPLE-REFERENCES-TO-EE>false</PERMIT-MULTIPLE-REFERENCES-TO-EE>
            </EXECUTION-ORDER-CONSTRAINT>
          </TIMING-REQUIREMENTS>
          <BEHAVIOR-REF DEST="BSW-INTERNAL-BEHAVIOR">/AUTOSAR_EthTrcv/BswModuleDescriptions/EthTrcv/BswInternalBehavior</BEHAVIOR-REF>
         </BSW-MODULE-TIMING>
        </ELEMENTS>
       </AR-PACKAGE>
      </AR-PACKAGES>
    </AR-PACKAGE>
  </AR-PACKAGES>
</AUTOSAR>
