              <SHORT-NAME>SoAd_StaticUdpConfigType_tst</SHORT-NAME>
              <LONG-NAME>
                <L-4 L="EN">This container specifies the Static Socket Connection Group Configuration Entry for Udp Protocol.</L-4>
              </LONG-NAME>
              <DESC>
