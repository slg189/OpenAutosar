                </IMPLEMENTATION-DATA-TYPE-ELEMENT>
                <IMPLEMENTATION-DATA-TYPE-ELEMENT>
                  <SHORT-NAME>triggerTransmission_en</SHORT-NAME>
                  <LONG-NAME>
                    <L-4 L="EN">Specifies whether a PDU triggers the transmission of the nPduUdpTxBuffer.</L-4>
                  </LONG-NAME>
                  <DESC>
                    <L-2 L="EN">Specifies whether a PDU triggers the transmission of the nPduUdpTxBuffer.</L-2>
                  </DESC>
