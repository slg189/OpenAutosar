<?xml version="1.0" encoding="UTF-8"?>
<AUTOSAR xmlns="http://autosar.org/schema/r4.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://autosar.org/schema/r4.0 AUTOSAR_4-3-0.xsd">
  <AR-PACKAGES>
    <AR-PACKAGE>
      <SHORT-NAME>AUTOSAR_SoAd</SHORT-NAME>
      <AR-PACKAGES>
        <AR-PACKAGE>
          <SHORT-NAME>TimingExtensions</SHORT-NAME>
          <ELEMENTS>
            <BSW-MODULE-TIMING>
              <SHORT-NAME>SoAd</SHORT-NAME>
              <TIMING-DESCRIPTIONS>
                <TD-EVENT-BSW-INTERNAL-BEHAVIOR>
                  <SHORT-NAME>EOC_T_xxms</SHORT-NAME>
                  <BSW-MODULE-ENTITY-REF DEST="BSW-SCHEDULABLE-ENTITY">/AUTOSAR_SoAd/BswModuleDescriptions/SoAd/BswInternalBehavior/SE_MainFunction</BSW-MODULE-ENTITY-REF>
                </TD-EVENT-BSW-INTERNAL-BEHAVIOR>
                <TD-EVENT-BSW-MODULE>
                  <SHORT-NAME>EOC_SoAd_Init</SHORT-NAME>
                  <BSW-MODULE-DESCRIPTION-REF DEST="BSW-MODULE-DESCRIPTION">/AUTOSAR_SoAd/BswModuleDescriptions/SoAd</BSW-MODULE-DESCRIPTION-REF>
                  <BSW-MODULE-ENTRY-REF DEST="BSW-MODULE-ENTRY">/AUTOSAR_SoAd/BswModuleEntrys/SoAd_Init</BSW-MODULE-ENTRY-REF>
                  <TD-EVENT-BSW-MODULE-TYPE>BSW-M-ENTRY-CALLED</TD-EVENT-BSW-MODULE-TYPE>
                </TD-EVENT-BSW-MODULE>
              </TIMING-DESCRIPTIONS>
              <TIMING-GUARANTEES>
                <EXECUTION-ORDER-CONSTRAINT>
                  <SHORT-NAME>EOC_T_xxms</SHORT-NAME>
                  <EXECUTION-ORDER-CONSTRAINT-TYPE>ORDINARY-EOC</EXECUTION-ORDER-CONSTRAINT-TYPE>
                  <IS-EVENT>true</IS-EVENT>
                  <ORDERED-ELEMENTS>
                    <EOC-EVENT-REF>
                      <SHORT-NAME>EOCEventRef_SoAd_1</SHORT-NAME>
                      <BSW-MODULE-INSTANCE-REF DEST="BSW-IMPLEMENTATION">/AUTOSAR_SoAd/BswImplementations/SoAd</BSW-MODULE-INSTANCE-REF>
                      <EVENT-REF DEST="BSW-TIMING-EVENT">/AUTOSAR_SoAd/BswModuleDescriptions/SoAd/BswInternalBehavior/EV_SE_MainFunction</EVENT-REF>
                      <SUCCESSOR-REFS>
                        <SUCCESSOR-REF DEST="EOC-EVENT-REF">/AUTOSAR_TcpIp/TimingExtensions/TcpIp/EOC_T_xxms/EOCEventRef_TcpIp_1</SUCCESSOR-REF>
                      </SUCCESSOR-REFS>
                    </EOC-EVENT-REF>
                  </ORDERED-ELEMENTS>
                  <PERMIT-MULTIPLE-REFERENCES-TO-EE>false</PERMIT-MULTIPLE-REFERENCES-TO-EE>
                </EXECUTION-ORDER-CONSTRAINT>
              </TIMING-GUARANTEES>
              <BEHAVIOR-REF DEST="BSW-INTERNAL-BEHAVIOR">/AUTOSAR_SoAd/BswModuleDescriptions/SoAd/BswInternalBehavior</BEHAVIOR-REF>
            </BSW-MODULE-TIMING>
          </ELEMENTS>
        </AR-PACKAGE>
      </AR-PACKAGES>
    </AR-PACKAGE>
  </AR-PACKAGES>
</AUTOSAR>

