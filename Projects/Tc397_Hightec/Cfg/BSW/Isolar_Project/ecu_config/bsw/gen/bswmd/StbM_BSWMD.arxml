            <BSW-MODULE-ENTRY>
              <SHORT-NAME>StbM_TriggerTimeTransmission</SHORT-NAME>
              <LONG-NAME>
                <L-4 L="EN">Service to increment the global array timeBaseUpdateCounter</L-4>
              </LONG-NAME>
