                </SW-SERVICE-ARG>
                <SW-SERVICE-ARG>
                  <SHORT-NAME>offsetRecordTableHead</SHORT-NAME>
                  <DESC>
                    <L-2 L="EN">This parameter refers to Offset Time Base Record Table Header</L-2>
                  </DESC>
