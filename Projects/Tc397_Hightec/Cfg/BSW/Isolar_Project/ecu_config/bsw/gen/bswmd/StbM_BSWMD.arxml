              <SHORT-NAME>StbM_VirtualLocalTimeType</SHORT-NAME>
              <LONG-NAME>
                <L-4 L="EN">Variables of this type store time stamps of the Virtual Local Time.</L-4>
              </LONG-NAME>
              <DESC>
                <L-2 L="EN">Variables of this type store time stamps of the Virtual Local Time. Note : Refer SWS for other implementation data types (StbM_TimeBaseStatusType,StbM_TimeStampType,StbM_TimeStampExtendedType,StbM_UserDataType,StbM_SynchronizedTimeBaseType)</L-2>
              </DESC>
              <CATEGORY>STRUCTURE</CATEGORY>
              <SUB-ELEMENTS>
                <IMPLEMENTATION-DATA-TYPE-ELEMENT>
                  <SHORT-NAME>nanosecondsHi</SHORT-NAME>
                  <CATEGORY>TYPE_REFERENCE</CATEGORY>
                  <SW-DATA-DEF-PROPS>
                    <SW-DATA-DEF-PROPS-VARIANTS>
                      <SW-DATA-DEF-PROPS-CONDITIONAL>
                        <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_Platform/ImplementationDataTypes/uint32</IMPLEMENTATION-DATA-TYPE-REF>
