                      </SW-DATA-DEF-PROPS-CONDITIONAL>
                    </SW-DATA-DEF-PROPS-VARIANTS>
                  </SW-DATA-DEF-PROPS>
                </IMPLEMENTATION-DATA-TYPE-ELEMENT>
              </SUB-ELEMENTS>
              <TYPE-EMITTER>GLOBAL</TYPE-EMITTER>
            </IMPLEMENTATION-DATA-TYPE>
            <IMPLEMENTATION-DATA-TYPE>
              <SHORT-NAME>StbM_MeasurementType</SHORT-NAME>
              <LONG-NAME>
                <L-4 L="EN">Structure which contains additional measurement data.</L-4>
              </LONG-NAME>
              <DESC>
                <L-2 L="EN">Structure which contains additional measurement data Note : Refer SWS for other implementation data types (Ex:StbM_TimeDiffType,StbM_TimeStampType,StbM_TimeStampExtendedType,StbM_UserDataType,StbM_SynchronizedTimeBaseType)</L-2>
              </DESC>
