<?xml version="1.0" encoding="UTF-8"?>
<AUTOSAR xmlns="http://autosar.org/schema/r4.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://autosar.org/schema/r4.0 autosar_4-2-2.xsd">
  <AR-PACKAGES>
    <AR-PACKAGE>
      <SHORT-NAME>AUTOSAR_StbM</SHORT-NAME>
      <AR-PACKAGES>
        <AR-PACKAGE>
          <SHORT-NAME>TimingExtensions</SHORT-NAME>
          <ELEMENTS>
            <BSW-MODULE-TIMING>
              <SHORT-NAME>StbM_BswModuleTiming</SHORT-NAME>
              <TIMING-REQUIREMENTS>
                <EXECUTION-ORDER-CONSTRAINT>
                  <SHORT-NAME>EOC_EcuM_Init</SHORT-NAME>
                  <EXECUTION-ORDER-CONSTRAINT-TYPE>ORDINARY-EOC</EXECUTION-ORDER-CONSTRAINT-TYPE>
                  <IS-EVENT>false</IS-EVENT>
                  <ORDERED-ELEMENTS>
                    <EOC-EXECUTABLE-ENTITY-REF>
                      <SHORT-NAME>EOCEERef_BSWCE_StbM_Init</SHORT-NAME>
                      <BSW-MODULE-INSTANCE-REF DEST="BSW-IMPLEMENTATION">/AUTOSAR_StbM/BswImplementations/StbM</BSW-MODULE-INSTANCE-REF>
                      <EXECUTABLE-REF DEST="BSW-CALLED-ENTITY">/AUTOSAR_StbM/BswModuleDescriptions/StbM/IB_StbM/CE_StbM_Init</EXECUTABLE-REF>
                    </EOC-EXECUTABLE-ENTITY-REF>
                  </ORDERED-ELEMENTS>
                  <PERMIT-MULTIPLE-REFERENCES-TO-EE>false</PERMIT-MULTIPLE-REFERENCES-TO-EE>
                </EXECUTION-ORDER-CONSTRAINT>
                <EXECUTION-ORDER-CONSTRAINT>
                  <SHORT-NAME>EOC_T_xxms</SHORT-NAME>
                  <EXECUTION-ORDER-CONSTRAINT-TYPE>ORDINARY-EOC</EXECUTION-ORDER-CONSTRAINT-TYPE>
                  <IS-EVENT>true</IS-EVENT>
                  <ORDERED-ELEMENTS>
                    <EOC-EVENT-REF>
                      <SHORT-NAME>EOCEventRef_StbM_MainFunction</SHORT-NAME>
                      <BSW-MODULE-INSTANCE-REF DEST="BSW-IMPLEMENTATION">/AUTOSAR_StbM/BswImplementations/StbM</BSW-MODULE-INSTANCE-REF>
                      <EVENT-REF DEST="BSW-TIMING-EVENT">/AUTOSAR_StbM/BswModuleDescriptions/StbM/IB_StbM/TE_StbM_MainFunction</EVENT-REF>
                    </EOC-EVENT-REF>
                  </ORDERED-ELEMENTS>
                </EXECUTION-ORDER-CONSTRAINT>
              </TIMING-REQUIREMENTS>
            </BSW-MODULE-TIMING>
          </ELEMENTS>
        </AR-PACKAGE>
      </AR-PACKAGES>
    </AR-PACKAGE>
  </AR-PACKAGES>
</AUTOSAR>