              <LONG-NAME>
                <L-4 L="EN">Check if the initialization is already done.</L-4>
              </LONG-NAME>
              <DESC>
                <L-2 L="EN">Check if the initialization is already done.</L-2>
              </DESC>
              <SERVICE-ID>255</SERVICE-ID>
              <IS-REENTRANT>true</IS-REENTRANT>
              <IS-SYNCHRONOUS>true</IS-SYNCHRONOUS>
              <CALL-TYPE>REGULAR</CALL-TYPE>
              <EXECUTION-CONTEXT>UNSPECIFIED</EXECUTION-CONTEXT>
              <SW-SERVICE-IMPL-POLICY>STANDARD</SW-SERVICE-IMPL-POLICY>
              <RETURN-TYPE>
                <SHORT-NAME>boolean</SHORT-NAME>
                <CATEGORY>TYPE_REFERENCE</CATEGORY>
                <INTRODUCTION>
                  <P>
                    <L-1 L="EN">TRUE: driver is already initialized</L-1>
                  </P>
                  <P>
                    <L-1 L="EN">FALSE: driver is not initialized</L-1>
                  </P>
                </INTRODUCTION>
