                  <AR-PACKAGE>
                    <SHORT-NAME>CompuMethods</SHORT-NAME>
                    <ELEMENTS>
                <COMPU-METHOD>
                  <SHORT-NAME>rba_EthArp_ArpTableEntryState_ten</SHORT-NAME>
                  <CATEGORY>TEXTTABLE</CATEGORY>
                  <COMPU-INTERNAL-TO-PHYS>
                    <COMPU-SCALES>
                      <COMPU-SCALE>
                        <DESC>
                          <L-2 L="EN">State of the entry when she is free/not used in the process</L-2>
                        </DESC>
                        <LOWER-LIMIT INTERVAL-TYPE="CLOSED">1</LOWER-LIMIT>
                        <UPPER-LIMIT INTERVAL-TYPE="CLOSED">1</UPPER-LIMIT>
                        <COMPU-CONST>
                          <VT>RBA_ETHARP_FREE_ENTRY</VT>
                        </COMPU-CONST>
                      </COMPU-SCALE>
                      <COMPU-SCALE>
                        <DESC>
                          <L-2 L="EN">State of the entry when a ARP request must be sent. This state appears when we cannot send the frame to the first time</L-2>
                        </DESC>
                        <LOWER-LIMIT INTERVAL-TYPE="CLOSED">2</LOWER-LIMIT>
                        <UPPER-LIMIT INTERVAL-TYPE="CLOSED">2</UPPER-LIMIT>
                        <COMPU-CONST>
                          <VT>RBA_ETHARP_REQ_TO_BE_SENT</VT>
                        </COMPU-CONST>
                      </COMPU-SCALE>
                      <COMPU-SCALE>
                        <DESC>
                          <L-2 L="EN">State of the entry when a ARP reply must be sent for the ARP request received</L-2>
                        </DESC>
                        <LOWER-LIMIT INTERVAL-TYPE="CLOSED">3</LOWER-LIMIT>
                        <UPPER-LIMIT INTERVAL-TYPE="CLOSED">3</UPPER-LIMIT>
                        <COMPU-CONST>
                          <VT>RBA_ETHARP_RPLY_TO_BE_SENT</VT>
                        </COMPU-CONST>
