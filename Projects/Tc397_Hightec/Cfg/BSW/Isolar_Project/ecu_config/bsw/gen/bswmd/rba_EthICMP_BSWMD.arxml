                      <BSW-MODULE-ENTRY>
                        <SHORT-NAME>rba_EthIcmp_Init</SHORT-NAME>
                        <DESC>
                          <L-2 L="EN">By this API service the TCP/IP initializes the configuration pointer of EthIcmp.</L-2>
                        </DESC>
                        
                        <IS-REENTRANT>false</IS-REENTRANT>
                        <IS-SYNCHRONOUS>false</IS-SYNCHRONOUS>
                        <CALL-TYPE>REGULAR</CALL-TYPE>
                        <EXECUTION-CONTEXT>UNSPECIFIED</EXECUTION-CONTEXT>
                        <SW-SERVICE-IMPL-POLICY>STANDARD</SW-SERVICE-IMPL-POLICY>
                        <ARGUMENTS>
                          <SW-SERVICE-ARG>
                            <!--Name="IcmpConfig_pco", Kind="in", Type="rba_EthIcmp_Config_to", IsConst="False"-->
                            <SHORT-NAME>IcmpConfig_pco</SHORT-NAME>
                            <DESC>
                              <L-2 L="EN"></L-2>
                            </DESC>
                            <CATEGORY>DATA_REFERENCE</CATEGORY>
                            <DIRECTION>IN</DIRECTION>
                            <SW-DATA-DEF-PROPS>
                              <SW-DATA-DEF-PROPS-VARIANTS>
                                <SW-DATA-DEF-PROPS-CONDITIONAL>
                                  <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/RB/RBA/rba_EthIcmp/ImplementationDataTypes/rba_EthIcmp_Config_to</IMPLEMENTATION-DATA-TYPE-REF>
                                  <SW-IMPL-POLICY>CONST</SW-IMPL-POLICY>
                                </SW-DATA-DEF-PROPS-CONDITIONAL>
                              </SW-DATA-DEF-PROPS-VARIANTS>
                            </SW-DATA-DEF-PROPS>
                          </SW-SERVICE-ARG>
                        </ARGUMENTS>
                      </BSW-MODULE-ENTRY>
                      <BSW-MODULE-ENTRY>
