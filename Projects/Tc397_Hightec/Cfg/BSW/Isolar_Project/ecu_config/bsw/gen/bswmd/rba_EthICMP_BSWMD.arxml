                  <AR-PACKAGE>
                    <SHORT-NAME>CompuMethods</SHORT-NAME>
                    <ELEMENTS>
                    <COMPU-METHOD>
                  <SHORT-NAME>rba_EthIcmp_DestUnreach_ten</SHORT-NAME>
                  <CATEGORY>TEXTTABLE</CATEGORY>
                  <COMPU-INTERNAL-TO-PHYS>
                    <COMPU-SCALES>
                      <COMPU-SCALE>
                        <DESC>
                          <L-2 L="EN">Destination network unreachable</L-2>
                        </DESC>
                        <LOWER-LIMIT INTERVAL-TYPE="CLOSED">0</LOWER-LIMIT>
                        <UPPER-LIMIT INTERVAL-TYPE="CLOSED">0</UPPER-LIMIT>
                        <COMPU-CONST>
                          <VT>RBA_ETHICMP_DEST_UNREACH_NET_E</VT>
                        </COMPU-CONST>
                      </COMPU-SCALE>
                      <COMPU-SCALE>
                        <DESC>
                          <L-2 L="EN">Destination host unreachable</L-2>
                        </DESC>
                        <LOWER-LIMIT INTERVAL-TYPE="CLOSED">1</LOWER-LIMIT>
                        <UPPER-LIMIT INTERVAL-TYPE="CLOSED">1</UPPER-LIMIT>
                        <COMPU-CONST>
                          <VT>RBA_ETHICMP_DEST_UNREACH_HOST_E</VT>
                        </COMPU-CONST>
                      </COMPU-SCALE>
                      <COMPU-SCALE>
                        <DESC>
                          <L-2 L="EN">Destination protocol unreachable</L-2>
                        </DESC>
                        <LOWER-LIMIT INTERVAL-TYPE="CLOSED">2</LOWER-LIMIT>
                        <UPPER-LIMIT INTERVAL-TYPE="CLOSED">2</UPPER-LIMIT>
                        <COMPU-CONST>
                          <VT>RBA_ETHICMP_DEST_UNREACH_PROTO_E</VT>
                        </COMPU-CONST>
                      </COMPU-SCALE>
                      <COMPU-SCALE>
                        <DESC>
                          <L-2 L="EN">Destination port unreachable</L-2>
                        </DESC>
                        <LOWER-LIMIT INTERVAL-TYPE="CLOSED">3</LOWER-LIMIT>
                        <UPPER-LIMIT INTERVAL-TYPE="CLOSED">3</UPPER-LIMIT>
                        <COMPU-CONST>
                          <VT> RBA_ETHICMP_DEST_UNREACH_PORT_E</VT>
                        </COMPU-CONST>
                      </COMPU-SCALE>
                      <COMPU-SCALE>
                        <DESC>
                          <L-2 L="EN">Fragmentation required, and DF flag set </L-2>
                        </DESC>
                        <LOWER-LIMIT INTERVAL-TYPE="CLOSED">4</LOWER-LIMIT>
                        <UPPER-LIMIT INTERVAL-TYPE="CLOSED">4</UPPER-LIMIT>
                        <COMPU-CONST>
                          <VT>RBA_ETHICMP_DEST_UNREACH_FRAG_E </VT>
                        </COMPU-CONST>
                      </COMPU-SCALE>
                      <COMPU-SCALE>
                        <DESC>
                          <L-2 L="EN">Source route failed</L-2>
                        </DESC>
                        <LOWER-LIMIT INTERVAL-TYPE="CLOSED">5</LOWER-LIMIT>
                        <UPPER-LIMIT INTERVAL-TYPE="CLOSED">5</UPPER-LIMIT>
                        <COMPU-CONST>
                          <VT> RBA_ETHICMP_DEST_UNREACH_SRC_FAIL_E </VT>
                        </COMPU-CONST>
                      </COMPU-SCALE>                      
                      </COMPU-SCALES>
                  </COMPU-INTERNAL-TO-PHYS>
                </COMPU-METHOD>
                <COMPU-METHOD>
                  <SHORT-NAME>rba_EthIcmp_TimeExceed_ten</SHORT-NAME>
                  <CATEGORY>TEXTTABLE</CATEGORY>
                  <COMPU-INTERNAL-TO-PHYS>
                    <COMPU-SCALES>
                      <COMPU-SCALE>
                        <DESC>
