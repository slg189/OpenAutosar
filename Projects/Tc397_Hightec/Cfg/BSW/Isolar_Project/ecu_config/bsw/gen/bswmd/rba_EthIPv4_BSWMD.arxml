                    </BSW-MODULE-ENTRY>
                    <BSW-MODULE-ENTRY>
                            <SHORT-NAME>rba_EthIPv4_MainFunction</SHORT-NAME>
                            <LONG-NAME>
                                <L-4 L="EN">Public API rba_EthIPv4_MainFunction</L-4>
                            </LONG-NAME>
                            <DESC>
                                <L-2 L="EN">rba_EthIPv4_MainFunction implements reassembly timeout handling. It is called from TcpIp_MainFunction. rba_EthIPv4_MainFunction is called entity and shall not be scheduled.</L-2>
                            </DESC>
                            <INTRODUCTION>
                              <P>
                                <L-1 L="EN">The service of This function decrements reassembly timer by value corresponding to
                                        TCPIP_MAIN_FUNCTIONPERIOD_MS releases the reassembly resources and triggers
                                        transmission of ICMP Time Exceeded message upon timeout.</L-1>
                             </P>
                            </INTRODUCTION>
                            <IS-REENTRANT>false</IS-REENTRANT>
                            <IS-SYNCHRONOUS>true</IS-SYNCHRONOUS>
                            <CALL-TYPE>REGULAR</CALL-TYPE>
                            <EXECUTION-CONTEXT>TASK</EXECUTION-CONTEXT>
                            <SW-SERVICE-IMPL-POLICY>STANDARD</SW-SERVICE-IMPL-POLICY>
                        </BSW-MODULE-ENTRY>
                        <BSW-MODULE-ENTRY>
                      <SHORT-NAME>rba_EthIPv4_GetAndResetMeasurementData</SHORT-NAME>
                      <LONG-NAME>
                        <L-4 L="EN">Public API rba_EthIPv4_GetAndResetMeasurementData</L-4>
                      </LONG-NAME>
                      <DESC>
                        <L-2 L="EN">Get all MeasurementIdx's at once is not supported. TCPIP_MEAS_ALL shall only be used to reset all MeasurementIdx's at once.
                                    A NULL_PTR shall be provided for MeasurementDataPtr in this case.</L-2>
                      </DESC>
                      <INTRODUCTION>
                        <P>
                          <L-1 L="EN">The service of This function Allows to read and reset detailed measurement data for diagnostic purposes.
                                     Get all MeasurementIdx's at once is not supported.TCPIP_MEAS_ALL shall only be used to reset all MeasurementIdx's at once.
                                     A NULL_PTR shall be provided for MeasurementDataPtr in this case.</L-1>
                        </P>
                      </INTRODUCTION>
                      <IS-REENTRANT>true</IS-REENTRANT>
                      <IS-SYNCHRONOUS>true</IS-SYNCHRONOUS>
                      <CALL-TYPE>REGULAR</CALL-TYPE>
                      <EXECUTION-CONTEXT>UNSPECIFIED</EXECUTION-CONTEXT>
                      <SW-SERVICE-IMPL-POLICY>STANDARD</SW-SERVICE-IMPL-POLICY>
                      <ARGUMENTS>
                        <SW-SERVICE-ARG>
                          <!--Name="MeasurementIdx_u8", Kind="in", Type="TcpIp_MeasurementIdxType", IsConst="false" -->
                          <SHORT-NAME>MeasurementIdx_u8</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Data index of measurement data.</L-2>
                          </DESC>
                          <CATEGORY>TYPE_REFERENCE</CATEGORY>
                          <DIRECTION>IN</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>
                                <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_TcpIp/ImplementationDataTypes/TcpIp_MeasurementIdxType</IMPLEMENTATION-DATA-TYPE-REF>
                                <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>
                        <SW-SERVICE-ARG>
                        <!--Name="MeasurementResetNeeded_b", Kind="in", Type="boolean", IsConst="false" -->
                          <SHORT-NAME>MeasurementResetNeeded_b</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Flag to trigger a reset of the measurement data. </L-2>
                          </DESC>
                          <CATEGORY>TYPE_REFERENCE</CATEGORY>
                          <DIRECTION>IN</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>
                                <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_Platform/ImplementationDataTypes/boolean</IMPLEMENTATION-DATA-TYPE-REF>
                                <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>
                        <SW-SERVICE-ARG>
                          <!--Name="MeasurementDataPtr_pu32", Kind="out", Type="uint32*", IsConst="false" -->
                          <SHORT-NAME>MeasurementDataPtr_pu32</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Reference to data buffer, where to copy measurement data. </L-2>
                          </DESC>
                          <CATEGORY>DATA_REFERENCE</CATEGORY>
                          <DIRECTION>OUT</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>                               
                                <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                                <SW-POINTER-TARGET-PROPS>
                                  <TARGET-CATEGORY>VALUE</TARGET-CATEGORY>
                                  <SW-DATA-DEF-PROPS>
                                    <SW-DATA-DEF-PROPS-VARIANTS>
                                      <SW-DATA-DEF-PROPS-CONDITIONAL>
                                        <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_Platform/ImplementationDataTypes/uint32</IMPLEMENTATION-DATA-TYPE-REF>
                                        <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                                      </SW-DATA-DEF-PROPS-CONDITIONAL>
                                    </SW-DATA-DEF-PROPS-VARIANTS>
                                  </SW-DATA-DEF-PROPS>
                                </SW-POINTER-TARGET-PROPS>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>                       
                      </ARGUMENTS>
                    </BSW-MODULE-ENTRY>
                        <BSW-MODULE-ENTRY>
                      <SHORT-NAME>rba_EthIPv4_CheckFragmentation</SHORT-NAME>
                      <LONG-NAME>
                        <L-4 L="EN">Public API rba_EthIPv4_CheckFragmentation</L-4>
                      </LONG-NAME>
                      <DESC>
                        <L-2 L="EN">The API returns the number of IPv4 fragments required to transmit the data with length provided in input parameter.</L-2>
                      </DESC>
                      <INTRODUCTION>
                        <P>
                          <L-1 L="EN">The service of the API is returns the number of IPv4 fragments required to transmit the data with length provided in input parameter.</L-1>
                        </P>
                      </INTRODUCTION>
                      <IS-REENTRANT>true</IS-REENTRANT>
                      <IS-SYNCHRONOUS>true</IS-SYNCHRONOUS>
                      <CALL-TYPE>REGULAR</CALL-TYPE>
                      <EXECUTION-CONTEXT>UNSPECIFIED</EXECUTION-CONTEXT>
                      <SW-SERVICE-IMPL-POLICY>STANDARD</SW-SERVICE-IMPL-POLICY>
                      <RETURN-TYPE>
                        <SHORT-NAME>ReturnValue</SHORT-NAME>
                        <DESC>
                          <L-2 L="EN">E_OK: successful; E_NOT_OK: failed</L-2>
                        </DESC>
                        <CATEGORY>TYPE_REFERENCE</CATEGORY>
                        <DIRECTION>OUT</DIRECTION>
                        <SW-DATA-DEF-PROPS>
                          <SW-DATA-DEF-PROPS-VARIANTS>
                            <SW-DATA-DEF-PROPS-CONDITIONAL>
                              <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_Std/ImplementationDataTypes/Std_ReturnType</IMPLEMENTATION-DATA-TYPE-REF>
                              <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                            </SW-DATA-DEF-PROPS-CONDITIONAL>
                          </SW-DATA-DEF-PROPS-VARIANTS>
                        </SW-DATA-DEF-PROPS>
                      </RETURN-TYPE>
                      <ARGUMENTS>
                        <SW-SERVICE-ARG>
                          <SHORT-NAME>LocalAddrId_u8</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">LocalAddrId on which data is to be transmitted.</L-2>
                          </DESC>
                          <CATEGORY>TYPE_REFERENCE</CATEGORY>
                          <DIRECTION>IN</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>
                                <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_Platform/ImplementationDataTypes/uint8</IMPLEMENTATION-DATA-TYPE-REF>
                                <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
