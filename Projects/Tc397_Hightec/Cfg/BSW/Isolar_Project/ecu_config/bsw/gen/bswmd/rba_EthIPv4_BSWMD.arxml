                    <BSW-MODULE-ENTRY>
                      <SHORT-NAME>rba_EthIPv4_ZeroCopyFillHeader</SHORT-NAME>
                      <LONG-NAME>
                        <L-4 L="EN">Public API rba_EthIPv4_ZeroCopyFillHeader</L-4>
                      </LONG-NAME>
                      <DESC>
                        <L-2 L="EN">This API prefill the reusable part of the IPv4 header</L-2>
                      </DESC>
                      <INTRODUCTION>
                        <P>
                          <L-1 L="EN">The service of This API prefill the reusable part of the IPv4 header</L-1>
                        </P>
                      </INTRODUCTION>
                      <IS-REENTRANT>true</IS-REENTRANT>
                      <IS-SYNCHRONOUS>true</IS-SYNCHRONOUS>
                      <CALL-TYPE>REGULAR</CALL-TYPE>
                      <EXECUTION-CONTEXT>UNSPECIFIED</EXECUTION-CONTEXT>
                      <SW-SERVICE-IMPL-POLICY>STANDARD</SW-SERVICE-IMPL-POLICY>
                      <RETURN-TYPE>
                        <SHORT-NAME>ReturnValue</SHORT-NAME>
                        <DESC>
                          <L-2 L="EN">Returns TCPIP_OK if IPv4 header filling successful. Returns TCPIP_E_NOT_OK if IPv4 header filling failed (general failure). Returns TCPIP_E_ARP_CACHE_MISS if IPv4 header filling failed because of ARP cache miss. </L-2>
                        </DESC>
                        <CATEGORY>TYPE_REFERENCE</CATEGORY>
                        <DIRECTION>OUT</DIRECTION>
                        <SW-DATA-DEF-PROPS>
                          <SW-DATA-DEF-PROPS-VARIANTS>
                            <SW-DATA-DEF-PROPS-CONDITIONAL>
                              <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_TcpIp/ImplementationDataTypes/TcpIp_ReturnType</IMPLEMENTATION-DATA-TYPE-REF>                              
                              <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>                            
                            </SW-DATA-DEF-PROPS-CONDITIONAL>
                          </SW-DATA-DEF-PROPS-VARIANTS>
                        </SW-DATA-DEF-PROPS>
                      </RETURN-TYPE>
                      <ARGUMENTS>
                        <SW-SERVICE-ARG>
                          <SHORT-NAME>LocalAddrId_u8</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">LocalAddrId on which data is to be transmitted.</L-2>
                          </DESC>
                          <CATEGORY>TYPE_REFERENCE</CATEGORY>
                          <DIRECTION>IN</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>
                                <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_Platform/ImplementationDataTypes/uint8</IMPLEMENTATION-DATA-TYPE-REF>
                                <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>
                        <SW-SERVICE-ARG>
                          <SHORT-NAME>Priority_u8</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Priority value which shall be used for the 3-bit PCP field of the VLAN tag.</L-2>
                          </DESC>
                          <CATEGORY>TYPE_REFERENCE</CATEGORY>
                          <DIRECTION>IN</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>
                                <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_Platform/ImplementationDataTypes/uint8</IMPLEMENTATION-DATA-TYPE-REF>
                                <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>
                        <SW-SERVICE-ARG>
                          <SHORT-NAME>DestIpAddr_u32</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Destination IP address to which the frame has to be transmitted.</L-2>
                          </DESC>
                          <CATEGORY>TYPE_REFERENCE</CATEGORY>
                          <DIRECTION>IN</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>
                                <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_Platform/ImplementationDataTypes/uint32</IMPLEMENTATION-DATA-TYPE-REF>
                                <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>
                        <SW-SERVICE-ARG>
                          <SHORT-NAME>IpHeader_pcst</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Data structure containing the fields of the IP header.</L-2>
                          </DESC>
                          <CATEGORY>DATA_REFERENCE</CATEGORY>
                          <DIRECTION>IN</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>                                
                                <SW-IMPL-POLICY>CONST</SW-IMPL-POLICY>
                                <SW-POINTER-TARGET-PROPS>
                                  <TARGET-CATEGORY>VALUE</TARGET-CATEGORY>
                                  <SW-DATA-DEF-PROPS>
                                    <SW-DATA-DEF-PROPS-VARIANTS>
                                      <SW-DATA-DEF-PROPS-CONDITIONAL>
                                        <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_TcpIp/ImplementationDataTypes/TcpIp_IpHeader_tst</IMPLEMENTATION-DATA-TYPE-REF>
                                        <SW-IMPL-POLICY>CONST</SW-IMPL-POLICY>
                                      </SW-DATA-DEF-PROPS-CONDITIONAL>
                                    </SW-DATA-DEF-PROPS-VARIANTS>
                                  </SW-DATA-DEF-PROPS>
                                </SW-POINTER-TARGET-PROPS>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>
                        <SW-SERVICE-ARG>
                          <SHORT-NAME>UdpDataLength_u16</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN"> Udp data length to be transmitted.</L-2>
                          </DESC>
                          <CATEGORY>TYPE_REFERENCE</CATEGORY>
                          <DIRECTION>IN</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>
                                <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_Platform/ImplementationDataTypes/uint16</IMPLEMENTATION-DATA-TYPE-REF>
                                <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>
                        <SW-SERVICE-ARG>
                          <SHORT-NAME>ZeroCopyArg_pcst</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">ZeroCopy argument containing the allocated headers and the pointer to the UL data to be transmitted.</L-2>
                          </DESC>
                          <CATEGORY>DATA_REFERENCE</CATEGORY>
                          <DIRECTION>IN</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>                                
                                <SW-IMPL-POLICY>CONST</SW-IMPL-POLICY>
                                <SW-POINTER-TARGET-PROPS>
                                  <TARGET-CATEGORY>VALUE</TARGET-CATEGORY>
                                  <SW-DATA-DEF-PROPS>
                                    <SW-DATA-DEF-PROPS-VARIANTS>
                                      <SW-DATA-DEF-PROPS-CONDITIONAL>
                                        <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_EthIf/ImplementationDataTypes/Eth_ZeroCopyArg_tst</IMPLEMENTATION-DATA-TYPE-REF>
                                        <SW-IMPL-POLICY>CONST</SW-IMPL-POLICY>
                                      </SW-DATA-DEF-PROPS-CONDITIONAL>
                                    </SW-DATA-DEF-PROPS-VARIANTS>
                                  </SW-DATA-DEF-PROPS>
