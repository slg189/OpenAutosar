                <AR-PACKAGE>
                  <SHORT-NAME>BswModuleEntrys</SHORT-NAME>
                  <ELEMENTS>

                    <BSW-MODULE-ENTRY>
                      <SHORT-NAME>rba_EthIPv4_ChkIPv4AddrType</SHORT-NAME>
                      <LONG-NAME>
                        <L-4 L="EN">Public API rba_EthIPv4_ChkIPv4AddrType</L-4>
                      </LONG-NAME>
                      <DESC>
                        <L-2 L="EN">Returns the IPv4 destination address type - Unicast / Broadcast / Multicast.</L-2>
                      </DESC>
                      <INTRODUCTION>
                        <P>
                          <L-1 L="EN">The service Returns the IPv4 destination address type
                                    Unicast / Broadcast / Multicast.</L-1>
                        </P>
                      </INTRODUCTION>
                      <IS-REENTRANT>false</IS-REENTRANT>
                      <IS-SYNCHRONOUS>true</IS-SYNCHRONOUS>
                      <CALL-TYPE>REGULAR</CALL-TYPE>
                      <EXECUTION-CONTEXT>UNSPECIFIED</EXECUTION-CONTEXT>
                      <SW-SERVICE-IMPL-POLICY>STANDARD</SW-SERVICE-IMPL-POLICY>
                      <RETURN-TYPE>
                        <SHORT-NAME>ReturnValue</SHORT-NAME>
                        <DESC>
                          <L-2 L="EN">Unicast OR Multicast OR Broadcast.</L-2>
                        </DESC>
                        <CATEGORY>TYPE_REFERENCE</CATEGORY>
                        <DIRECTION>OUT</DIRECTION>
                        <SW-DATA-DEF-PROPS>
                          <SW-DATA-DEF-PROPS-VARIANTS>
                            <SW-DATA-DEF-PROPS-CONDITIONAL>
                              <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_TcpIp/ImplementationDataTypes/TcpIp_AddressType</IMPLEMENTATION-DATA-TYPE-REF>
                              <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                            </SW-DATA-DEF-PROPS-CONDITIONAL>
                          </SW-DATA-DEF-PROPS-VARIANTS>
                        </SW-DATA-DEF-PROPS>
                      </RETURN-TYPE>
                      <ARGUMENTS>
                        <SW-SERVICE-ARG>
                          <!--Name="DestIpAddr_u32", Kind="in", Type="uint32", IsConst="false" -->
                          <SHORT-NAME>DestIpAddr_u32</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Destination IPv4 address type. </L-2>
                          </DESC>
                          <CATEGORY>TYPE_REFERENCE</CATEGORY>
                          <DIRECTION>IN</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>
                                <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_Platform/ImplementationDataTypes/uint32</IMPLEMENTATION-DATA-TYPE-REF>
                                <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>
                        <SW-SERVICE-ARG>
                          <!--Name="SrcIpAddr_u32", Kind="in", Type="uint32", IsConst="false" -->
                          <SHORT-NAME>SrcIpAddr_u32</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Source IPv4 address type.</L-2>
                          </DESC>
                          <CATEGORY>TYPE_REFERENCE</CATEGORY>
                          <DIRECTION>IN</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>
                                <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_Platform/ImplementationDataTypes/uint32</IMPLEMENTATION-DATA-TYPE-REF>
                                <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>
                        <SW-SERVICE-ARG>
                          <!--Name="NetMask_u32", Kind="in", Type="uint32", IsConst="false" -->
                          <SHORT-NAME>NetMask_u32</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">NetMask of the LocalAddr Index.</L-2>
                          </DESC>
                          <CATEGORY>TYPE_REFERENCE</CATEGORY>
                          <DIRECTION>IN</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>
                                <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_Platform/ImplementationDataTypes/uint32</IMPLEMENTATION-DATA-TYPE-REF>
                                <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>
                      </ARGUMENTS>
                    </BSW-MODULE-ENTRY>
                    <BSW-MODULE-ENTRY>
                      <SHORT-NAME>rba_EthIPv4_GetIPMulticastDestEthAddr</SHORT-NAME>
                      <LONG-NAME>
                        <L-4 L="EN">Public API rba_EthIPv4_GetIPMulticastDestEthAddr</L-4>
                      </LONG-NAME>
                      <DESC>
                        <L-2 L="EN">Return the multicast Ethernet address for multicast IPv4 destination address. Upper half of destination Ethernet address for multicast IP address is 01:00:5E. The lower half comes from the lower 23 bits of the multicast destination IP address. The 24th bit of the destination MAC address is always set to 0 for multicast IP address. </L-2>
                      </DESC>
                      <INTRODUCTION>
                        <P>
                          <L-1 L="EN">The service Returns the multicast Ethernet address for
                                    multicast IPv4 destination address.</L-1>
                        </P>
                      </INTRODUCTION>
                      <IS-REENTRANT>false</IS-REENTRANT>
                      <IS-SYNCHRONOUS>true</IS-SYNCHRONOUS>
                      <CALL-TYPE>REGULAR</CALL-TYPE>
                      <EXECUTION-CONTEXT>UNSPECIFIED</EXECUTION-CONTEXT>
                      <SW-SERVICE-IMPL-POLICY>STANDARD</SW-SERVICE-IMPL-POLICY>
                      <ARGUMENTS>
                        <SW-SERVICE-ARG>
                          <!--Name="DestMultiCastIpAddr_u32", Kind="in", Type="uint32",
                                                        IsConst="false" -->
                          <SHORT-NAME>DestMultiCastIpAddr_u32</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Destination multicast IPv4 address.</L-2>
                          </DESC>
                          <CATEGORY>TYPE_REFERENCE</CATEGORY>
                          <DIRECTION>IN</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>
                                <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_Platform/ImplementationDataTypes/uint32</IMPLEMENTATION-DATA-TYPE-REF>
                                <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>
                        <SW-SERVICE-ARG>
                          <!--Name="DestEthAddr_pau8", Kind="out", Type="uint8", IsConst="false" -->
                          <SHORT-NAME>DestEthAddr_pau8</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Destination multicast Ethernet/MAC address.</L-2>
                          </DESC>
                          <CATEGORY>DATA_REFERENCE</CATEGORY>
                          <DIRECTION>OUT</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>
                                <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                                <SW-POINTER-TARGET-PROPS>
                                  <TARGET-CATEGORY>VALUE</TARGET-CATEGORY>
                                  <SW-DATA-DEF-PROPS>
                                    <SW-DATA-DEF-PROPS-VARIANTS>
                                      <SW-DATA-DEF-PROPS-CONDITIONAL>
                                        <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_Platform/ImplementationDataTypes/uint8</IMPLEMENTATION-DATA-TYPE-REF>
                                        <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                                      </SW-DATA-DEF-PROPS-CONDITIONAL>
                                    </SW-DATA-DEF-PROPS-VARIANTS>
                                  </SW-DATA-DEF-PROPS>
                                </SW-POINTER-TARGET-PROPS>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>
                      </ARGUMENTS>
                    </BSW-MODULE-ENTRY>
                    <BSW-MODULE-ENTRY>
                      <SHORT-NAME>rba_EthIPv4_Init</SHORT-NAME>
                      <LONG-NAME>
                        <L-4 L="EN">Public API rba_EthIPv4_Init</L-4>
                      </LONG-NAME>
                      <DESC>
                        <L-2 L="EN">This function Initializes the rba_EthIPv4 module.</L-2>
                      </DESC>
                      <INTRODUCTION>
                        <P>
                          <L-1 L="EN">The service initializes global variables, data
                                    structures and all rba_EthIPv4 submodules.</L-1>
                        </P>
                      </INTRODUCTION>
                      <IS-REENTRANT>false</IS-REENTRANT>
                      <IS-SYNCHRONOUS>true</IS-SYNCHRONOUS>
                      <CALL-TYPE>REGULAR</CALL-TYPE>
                      <EXECUTION-CONTEXT>UNSPECIFIED</EXECUTION-CONTEXT>
                      <SW-SERVICE-IMPL-POLICY>STANDARD</SW-SERVICE-IMPL-POLICY>
                      <ARGUMENTS>
                        <SW-SERVICE-ARG>
                          <!--Name="CurrConfig_pco", Kind="in", Type="rba_EthIPv4_Config_to*",
                                                        IsConst="True" -->
                          <SHORT-NAME>CurrConfig_pco</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Configuration data structure for rba_EthIPv4 module.</L-2>
                          </DESC>
                          <CATEGORY>DATA_REFERENCE</CATEGORY>
                          <DIRECTION>IN</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>                                
                                <SW-IMPL-POLICY>CONST</SW-IMPL-POLICY>
                                <SW-POINTER-TARGET-PROPS>
                                  <TARGET-CATEGORY>VALUE</TARGET-CATEGORY>
                                  <SW-DATA-DEF-PROPS>
                                    <SW-DATA-DEF-PROPS-VARIANTS>
                                      <SW-DATA-DEF-PROPS-CONDITIONAL>
                                        <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/RB/RBA/rba_EthIPv4/ImplementationDataTypes/rba_EthIPv4_Config_to</IMPLEMENTATION-DATA-TYPE-REF>
                                        <SW-IMPL-POLICY>CONST</SW-IMPL-POLICY>
                                      </SW-DATA-DEF-PROPS-CONDITIONAL>
                                    </SW-DATA-DEF-PROPS-VARIANTS>
                                  </SW-DATA-DEF-PROPS>
                                </SW-POINTER-TARGET-PROPS>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>
                      </ARGUMENTS>
                    </BSW-MODULE-ENTRY>
                    <BSW-MODULE-ENTRY>
                      <SHORT-NAME>rba_EthIPv4_ProvideTxBuffer</SHORT-NAME>
                      <LONG-NAME>
                        <L-4 L="EN">Public API rba_EthIPv4_ProvideTxBuffer</L-4>
                      </LONG-NAME>
                      <DESC>
                        <L-2 L="EN">This API provides transmission buffer to the upper layer.</L-2>
                      </DESC>
                      <INTRODUCTION>
                        <P>
                          <L-1 L="EN">The service of This API provides transmission buffer to the upper layer and
                                    returns Result of buffer request.</L-1>
                        </P>
                      </INTRODUCTION>
                      <IS-REENTRANT>false</IS-REENTRANT>
                      <IS-SYNCHRONOUS>true</IS-SYNCHRONOUS>
                      <CALL-TYPE>REGULAR</CALL-TYPE>
                      <EXECUTION-CONTEXT>UNSPECIFIED</EXECUTION-CONTEXT>
                      <SW-SERVICE-IMPL-POLICY>STANDARD</SW-SERVICE-IMPL-POLICY>
                      <RETURN-TYPE>
                        <SHORT-NAME>ReturnValue</SHORT-NAME>
                        <DESC>
                          <L-2 L="EN">BUFREQ_OK: success.
                          BUFREQ_E_NOT_OK: development error detected.
                          BUFREQ_E_BUSY: all buffers in use.
                          BUFREQ_E_OVFL: requested length is greater than buffer length.</L-2>
                        </DESC>
                        <CATEGORY>TYPE_REFERENCE</CATEGORY>
                        <DIRECTION>OUT</DIRECTION>
                        <SW-DATA-DEF-PROPS>
                          <SW-DATA-DEF-PROPS-VARIANTS>
                            <SW-DATA-DEF-PROPS-CONDITIONAL>
                              <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_Comtype/ImplementationDataTypes/BufReq_ReturnType</IMPLEMENTATION-DATA-TYPE-REF>
                              <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                            </SW-DATA-DEF-PROPS-CONDITIONAL>
                          </SW-DATA-DEF-PROPS-VARIANTS>
                        </SW-DATA-DEF-PROPS>
                      </RETURN-TYPE>
                      <ARGUMENTS>
                        <SW-SERVICE-ARG>
                          <!--Name="LocalAddrId_u8", Kind="in", Type="uint8", IsConst="false" -->
                          <SHORT-NAME>LocalAddrId_u8</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Local address index on which data is to be transmitted. </L-2>
                          </DESC>
                          <CATEGORY>TYPE_REFERENCE</CATEGORY>
                          <DIRECTION>IN</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>
                                <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_Platform/ImplementationDataTypes/uint8</IMPLEMENTATION-DATA-TYPE-REF>
                                <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>
                        <SW-SERVICE-ARG>
                          <!--Name="DestIpAddr_u32", Kind="in", Type="uint32", IsConst="false" -->
                          <SHORT-NAME>DestIpAddr_u32</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Destination IP address to which the data is to be transmitted. </L-2>
                          </DESC>
                          <CATEGORY>TYPE_REFERENCE</CATEGORY>
                          <DIRECTION>IN</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>
                                <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_Platform/ImplementationDataTypes/uint32</IMPLEMENTATION-DATA-TYPE-REF>
                                <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>
                        <SW-SERVICE-ARG>
                          <!--Name="FramePrio_u8", Kind="in", Type="uint8", IsConst="false" -->
                          <SHORT-NAME>FramePrio_u8</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Priority value which shall be used for the 3-bit PCP field of the VLAN tag.</L-2>
                          </DESC>
                          <CATEGORY>TYPE_REFERENCE</CATEGORY>
                          <DIRECTION>IN</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>
                                <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_Platform/ImplementationDataTypes/uint8</IMPLEMENTATION-DATA-TYPE-REF>
                                <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>
                        <SW-SERVICE-ARG>
                          <!--Name="BufIdx_pu8", Kind="inout", Type="uint8", IsConst="false" -->
                          <SHORT-NAME>BufIdx_pu8</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Index to the buffer allocated by EthDrv.</L-2>
                          </DESC>
                          <CATEGORY>DATA_REFERENCE</CATEGORY>
                          <DIRECTION>OUT</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>                                
                                <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                                <SW-POINTER-TARGET-PROPS>
                                  <TARGET-CATEGORY>VALUE</TARGET-CATEGORY>
                                  <SW-DATA-DEF-PROPS>
                                    <SW-DATA-DEF-PROPS-VARIANTS>
                                      <SW-DATA-DEF-PROPS-CONDITIONAL>
                                        <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_Platform/ImplementationDataTypes/uint8</IMPLEMENTATION-DATA-TYPE-REF>
                                        <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                                      </SW-DATA-DEF-PROPS-CONDITIONAL>
                                    </SW-DATA-DEF-PROPS-VARIANTS>
                                  </SW-DATA-DEF-PROPS>
                                </SW-POINTER-TARGET-PROPS>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>
                        <SW-SERVICE-ARG>
                          <!--Name="Buffer_ppu8", Kind="inout", Type="uint8*", IsConst="false" -->
                          <SHORT-NAME>Buffer_ppu8</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Starting address of the buffer.</L-2>
                          </DESC>
                          <CATEGORY>DATA_REFERENCE</CATEGORY>
                          <DIRECTION>OUT</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>                                
                                <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                                <SW-POINTER-TARGET-PROPS>
                                  <TARGET-CATEGORY>VALUE</TARGET-CATEGORY>
                                  <SW-DATA-DEF-PROPS>
                                    <SW-DATA-DEF-PROPS-VARIANTS>
                                      <SW-DATA-DEF-PROPS-CONDITIONAL>
                                        <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_Platform/ImplementationDataTypes/uint8</IMPLEMENTATION-DATA-TYPE-REF>
                                        <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                                      </SW-DATA-DEF-PROPS-CONDITIONAL>
                                    </SW-DATA-DEF-PROPS-VARIANTS>
                                  </SW-DATA-DEF-PROPS>
                                </SW-POINTER-TARGET-PROPS>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>
                        <SW-SERVICE-ARG>
                          <!--Name="ReqLengthIn_pu16", Kind="inout", Type="uint16", IsConst="false" -->
                          <SHORT-NAME>ReqLengthIn_pu16</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Length of buffer requested.</L-2>
                          </DESC>
                          <CATEGORY>DATA_REFERENCE</CATEGORY>
                          <DIRECTION>INOUT</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>                                
                                <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                                <SW-POINTER-TARGET-PROPS>
