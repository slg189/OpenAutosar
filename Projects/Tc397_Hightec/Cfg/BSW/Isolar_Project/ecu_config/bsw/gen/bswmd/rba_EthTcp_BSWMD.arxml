                </AR-PACKAGE>
                <AR-PACKAGE>
                  <SHORT-NAME>CompuMethods</SHORT-NAME>
                  <ELEMENTS>
                    <COMPU-METHOD>
                      <SHORT-NAME>rba_EthTcp_ConnState_ten</SHORT-NAME>
                      <CATEGORY>TEXTTABLE</CATEGORY>
                      <COMPU-INTERNAL-TO-PHYS>
                        <COMPU-SCALES>
                          <COMPU-SCALE>
                            <DESC>
                              <L-2 L="EN">No connection at all</L-2>
                            </DESC>
                            <LOWER-LIMIT INTERVAL-TYPE="CLOSED">0</LOWER-LIMIT>
                            <UPPER-LIMIT INTERVAL-TYPE="CLOSED">0</UPPER-LIMIT>
                            <COMPU-CONST>
                              <VT>RBA_ETHTCP_CONN_CLOSED_E</VT>
                            </COMPU-CONST>
                          </COMPU-SCALE>
                          <COMPU-SCALE>
                            <DESC>
                              <L-2 L="EN">Wait for a Connection Request from any remote TCP</L-2>
                            </DESC>
                            <LOWER-LIMIT INTERVAL-TYPE="CLOSED">1</LOWER-LIMIT>
                            <UPPER-LIMIT INTERVAL-TYPE="CLOSED">1</UPPER-LIMIT>
                            <COMPU-CONST>
                              <VT>RBA_ETHTCP_CONN_LISTEN_E</VT>
                            </COMPU-CONST>
                          </COMPU-SCALE>
                          <COMPU-SCALE>
                            <DESC>
                              <L-2 L="EN">Wait for a SYN-ACK after having sent a connection request</L-2>
                            </DESC>
                            <LOWER-LIMIT INTERVAL-TYPE="CLOSED">2</LOWER-LIMIT>
                            <UPPER-LIMIT INTERVAL-TYPE="CLOSED">2</UPPER-LIMIT>
                            <COMPU-CONST>
                              <VT>RBA_ETHTCP_CONN_SYN_SENT_E</VT>
                            </COMPU-CONST>
                          </COMPU-SCALE>
                          <COMPU-SCALE>
                            <DESC>
                              <L-2 L="EN">Wait for a Connection Request ACK after having both received and sent a connection request</L-2>
                            </DESC>
                            <LOWER-LIMIT INTERVAL-TYPE="CLOSED">3</LOWER-LIMIT>
                            <UPPER-LIMIT INTERVAL-TYPE="CLOSED">3</UPPER-LIMIT>
                            <COMPU-CONST>
                              <VT>RBA_ETHTCP_CONN_SYN_RCVD_E</VT>
                            </COMPU-CONST>
                          </COMPU-SCALE>
                          <COMPU-SCALE>
                            <DESC>
                              <L-2 L="EN">Data can be transmitted and received only in this state</L-2>
                            </DESC>
                            <LOWER-LIMIT INTERVAL-TYPE="CLOSED">4</LOWER-LIMIT>
                            <UPPER-LIMIT INTERVAL-TYPE="CLOSED">4</UPPER-LIMIT>
                            <COMPU-CONST>
                              <VT>RBA_ETHTCP_CONN_ESTABLISHED_E</VT>
                            </COMPU-CONST>
                          </COMPU-SCALE>
                          <COMPU-SCALE>
                            <DESC>
                              <L-2 L="EN">FIN frame has been sent, waiting for an ACK or Connection Termination Request from the Remote TCP</L-2>
                            </DESC>
                            <LOWER-LIMIT INTERVAL-TYPE="CLOSED">5</LOWER-LIMIT>
                            <UPPER-LIMIT INTERVAL-TYPE="CLOSED">5</UPPER-LIMIT>
                            <COMPU-CONST>
                              <VT>RBA_ETHTCP_CONN_FIN_WAIT_1_E</VT>
                            </COMPU-CONST>
                          </COMPU-SCALE>
                          <COMPU-SCALE>
                            <DESC>
                              <L-2 L="EN">Wait for Connection Termination Request from the Remote TCP</L-2>
                            </DESC>
                            <LOWER-LIMIT INTERVAL-TYPE="CLOSED">6</LOWER-LIMIT>
                            <UPPER-LIMIT INTERVAL-TYPE="CLOSED">6</UPPER-LIMIT>
                            <COMPU-CONST>
                              <VT>RBA_ETHTCP_CONN_FIN_WAIT_2_E</VT>
                            </COMPU-CONST>
                          </COMPU-SCALE>
                          <COMPU-SCALE>
                            <DESC>
                              <L-2 L="EN">Server TCP is waiting for Application to Close</L-2>
                            </DESC>
                            <LOWER-LIMIT INTERVAL-TYPE="CLOSED">7</LOWER-LIMIT>
                            <UPPER-LIMIT INTERVAL-TYPE="CLOSED">7</UPPER-LIMIT>
                            <COMPU-CONST>
                              <VT>RBA_ETHTCP_CONN_CLOSE_WAIT_E</VT>
                            </COMPU-CONST>
                          </COMPU-SCALE>
                          <COMPU-SCALE>
                            <DESC>
                              <L-2 L="EN">Wait for a connection termination request acknowledgment from the remote TCP</L-2>
                            </DESC>
                            <LOWER-LIMIT INTERVAL-TYPE="CLOSED">8</LOWER-LIMIT>
                            <UPPER-LIMIT INTERVAL-TYPE="CLOSED">8</UPPER-LIMIT>
                            <COMPU-CONST>
                              <VT>RBA_ETHTCP_CONN_CLOSING_E</VT>
                            </COMPU-CONST>
                          </COMPU-SCALE>
                          <COMPU-SCALE>
                            <DESC>
                              <L-2 L="EN">Wait for Connection Termination request Ack from Client TCP</L-2>
                            </DESC>
                            <LOWER-LIMIT INTERVAL-TYPE="CLOSED">9</LOWER-LIMIT>
                            <UPPER-LIMIT INTERVAL-TYPE="CLOSED">9</UPPER-LIMIT>
                            <COMPU-CONST>
                              <VT>RBA_ETHTCP_CONN_LAST_ACK_E</VT>
                            </COMPU-CONST>
                          </COMPU-SCALE>
                          <COMPU-SCALE>
                            <DESC>
                              <L-2 L="EN">Time to wait before closing TCP Connection</L-2>
                            </DESC>
                            <LOWER-LIMIT INTERVAL-TYPE="CLOSED">10</LOWER-LIMIT>
                            <UPPER-LIMIT INTERVAL-TYPE="CLOSED">10</UPPER-LIMIT>
                            <COMPU-CONST>
                              <VT>RBA_ETHTCP_CONN_TIME_WAIT_E</VT>
                            </COMPU-CONST>
                          </COMPU-SCALE>
                        </COMPU-SCALES>
                      </COMPU-INTERNAL-TO-PHYS>
                    </COMPU-METHOD>
                    <COMPU-METHOD>
                      <SHORT-NAME>rba_EthTcp_SocketState_ten</SHORT-NAME>
                      <CATEGORY>TEXTTABLE</CATEGORY>
                      <COMPU-INTERNAL-TO-PHYS>
                        <COMPU-SCALES>
                          <COMPU-SCALE>
                            <DESC>
                              <L-2 L="EN">Socket is Closed i.e. socket is not in use</L-2>
                            </DESC>
                            <LOWER-LIMIT INTERVAL-TYPE="CLOSED">0</LOWER-LIMIT>
                            <UPPER-LIMIT INTERVAL-TYPE="CLOSED">0</UPPER-LIMIT>
                            <COMPU-CONST>
                              <VT>RBA_ETHTCP_SOCK_CLOSED_E</VT>
                            </COMPU-CONST>
                          </COMPU-SCALE>
                          <COMPU-SCALE>
                            <DESC>
                              <L-2 L="EN">Socket is reserved by Tcp to send an immediate frame in reply</L-2>
                            </DESC>
                            <LOWER-LIMIT INTERVAL-TYPE="CLOSED">1</LOWER-LIMIT>
                            <UPPER-LIMIT INTERVAL-TYPE="CLOSED">1</UPPER-LIMIT>
                            <COMPU-CONST>
                              <VT>RBA_ETHTCP_SOCK_RESERVED_E</VT>
                            </COMPU-CONST>
                          </COMPU-SCALE>
                          <COMPU-SCALE>
                            <DESC>
                              <L-2 L="EN">Socket is allocated i.e. socket is reserved for use</L-2>
                            </DESC>
                            <LOWER-LIMIT INTERVAL-TYPE="CLOSED">2</LOWER-LIMIT>
                            <UPPER-LIMIT INTERVAL-TYPE="CLOSED">2</UPPER-LIMIT>
                            <COMPU-CONST>
                              <VT>RBA_ETHTCP_SOCK_ALLOCATED_E</VT>
                            </COMPU-CONST>
                          </COMPU-SCALE>
                          <COMPU-SCALE>
                            <DESC>
                              <L-2 L="EN">Socket is bound i.e. when local address is assigned to socket</L-2>
                            </DESC>
                            <LOWER-LIMIT INTERVAL-TYPE="CLOSED">3</LOWER-LIMIT>
                            <UPPER-LIMIT INTERVAL-TYPE="CLOSED">3</UPPER-LIMIT>
                            <COMPU-CONST>
                              <VT>RBA_ETHTCP_SOCK_BOUND_E</VT>
                            </COMPU-CONST>
                          </COMPU-SCALE>
                          <COMPU-SCALE>
                            <DESC>
                              <L-2 L="EN">Socket is opened for communication i.e. when Listen and Connect functions is called</L-2>
                            </DESC>
                            <LOWER-LIMIT INTERVAL-TYPE="CLOSED">4</LOWER-LIMIT>
                            <UPPER-LIMIT INTERVAL-TYPE="CLOSED">4</UPPER-LIMIT>
                            <COMPU-CONST>
                              <VT>RBA_ETHTCP_SOCK_OPENED_E</VT>
                            </COMPU-CONST>
                          </COMPU-SCALE>
                        </COMPU-SCALES>
                      </COMPU-INTERNAL-TO-PHYS>
                    </COMPU-METHOD>
                    <COMPU-METHOD>
                      <SHORT-NAME>rba_EthTcp_Flag_ten</SHORT-NAME>
                      <CATEGORY>TEXTTABLE</CATEGORY>
                      <COMPU-INTERNAL-TO-PHYS>
                        <COMPU-SCALES>
                          <COMPU-SCALE>
                            <DESC>
                              <L-2 L="EN">Do Nothing in the next main function</L-2>
                            </DESC>
                            <LOWER-LIMIT INTERVAL-TYPE="CLOSED">0</LOWER-LIMIT>
                            <UPPER-LIMIT INTERVAL-TYPE="CLOSED">0</UPPER-LIMIT>
                            <COMPU-CONST>
                              <VT>RBA_ETHTCP_NOTHING_E</VT>
                            </COMPU-CONST>
                          </COMPU-SCALE>
                          <COMPU-SCALE>
                            <DESC>
                              <L-2 L="EN">(Priority 1) Send a RST frame in the next main function</L-2>
                            </DESC>
                            <LOWER-LIMIT INTERVAL-TYPE="CLOSED">1</LOWER-LIMIT>
                            <UPPER-LIMIT INTERVAL-TYPE="CLOSED">1</UPPER-LIMIT>
                            <COMPU-CONST>
                              <VT>RBA_ETHTCP_SEND_RST_E</VT>
                            </COMPU-CONST>
                          </COMPU-SCALE>
                          <COMPU-SCALE>
                            <DESC>
                              <L-2 L="EN">(Priority 2) Send a RST ACK frame in the next main function</L-2>
                            </DESC>
                            <LOWER-LIMIT INTERVAL-TYPE="CLOSED">2</LOWER-LIMIT>
                            <UPPER-LIMIT INTERVAL-TYPE="CLOSED">2</UPPER-LIMIT>
                            <COMPU-CONST>
                              <VT>RBA_ETHTCP_SEND_RST_ACK_E</VT>
                            </COMPU-CONST>
                          </COMPU-SCALE>
                          <COMPU-SCALE>
                            <DESC>
                              <L-2 L="EN">(Priority 3) Send an ACK for the received FIN ACK in the next main function</L-2>
                            </DESC>
                            <LOWER-LIMIT INTERVAL-TYPE="CLOSED">3</LOWER-LIMIT>
                            <UPPER-LIMIT INTERVAL-TYPE="CLOSED">3</UPPER-LIMIT>
                            <COMPU-CONST>
                              <VT>RBA_ETHTCP_SEND_ACK_FOR_FIN_ACK_E</VT>
                            </COMPU-CONST>
                          </COMPU-SCALE>
                          <COMPU-SCALE>
                            <DESC>
                              <L-2 L="EN">(Priority 4) Send a FIN ACK in the next main function</L-2>
                            </DESC>
                            <LOWER-LIMIT INTERVAL-TYPE="CLOSED">4</LOWER-LIMIT>
                            <UPPER-LIMIT INTERVAL-TYPE="CLOSED">4</UPPER-LIMIT>
                            <COMPU-CONST>
                              <VT>RBA_ETHTCP_SEND_FIN_ACK_E</VT>
                            </COMPU-CONST>
                          </COMPU-SCALE>
                          <COMPU-SCALE>
                            <DESC>
                              <L-2 L="EN">(Priority 5) Send ACK for the received SYN ACK in the next main function</L-2>
                            </DESC>
                            <LOWER-LIMIT INTERVAL-TYPE="CLOSED">5</LOWER-LIMIT>
                            <UPPER-LIMIT INTERVAL-TYPE="CLOSED">5</UPPER-LIMIT>
                            <COMPU-CONST>
                              <VT>RBA_ETHTCP_SEND_ACK_FOR_SYN_ACK_E</VT>
                            </COMPU-CONST>
                          </COMPU-SCALE>
                          <COMPU-SCALE>
                            <DESC>
                              <L-2 L="EN">(Priority 6) Send a SYN ACK for the received SYN in the next main function</L-2>
                            </DESC>
                            <LOWER-LIMIT INTERVAL-TYPE="CLOSED">6</LOWER-LIMIT>
                            <UPPER-LIMIT INTERVAL-TYPE="CLOSED">6</UPPER-LIMIT>
                            <COMPU-CONST>
                              <VT>RBA_ETHTCP_SEND_SYN_ACK_E</VT>
                            </COMPU-CONST>
                          </COMPU-SCALE>
                          <COMPU-SCALE>
                            <DESC>
                              <L-2 L="EN">(Priority 7) Send a SYN in the next main function</L-2>
                            </DESC>
                            <LOWER-LIMIT INTERVAL-TYPE="CLOSED">7</LOWER-LIMIT>
                            <UPPER-LIMIT INTERVAL-TYPE="CLOSED">7</UPPER-LIMIT>
                            <COMPU-CONST>
                              <VT>RBA_ETHTCP_SEND_SYN_E</VT>
                            </COMPU-CONST>
                          </COMPU-SCALE>
                          <COMPU-SCALE>
                            <DESC>
                              <L-2 L="EN">(Priority 8) Send a Zero Window Probe in the next main function</L-2>
                            </DESC>
                            <LOWER-LIMIT INTERVAL-TYPE="CLOSED">8</LOWER-LIMIT>
                            <UPPER-LIMIT INTERVAL-TYPE="CLOSED">8</UPPER-LIMIT>
                            <COMPU-CONST>
                              <VT>RBA_ETHTCP_SEND_ZWP_E</VT>
                            </COMPU-CONST>
                          </COMPU-SCALE>
                          <COMPU-SCALE>
                            <DESC>
                              <L-2 L="EN">(Priority 9) Send data in the next main function</L-2>
                            </DESC>
                            <LOWER-LIMIT INTERVAL-TYPE="CLOSED">9</LOWER-LIMIT>
                            <UPPER-LIMIT INTERVAL-TYPE="CLOSED">9</UPPER-LIMIT>
                            <COMPU-CONST>
                              <VT>RBA_ETHTCP_SEND_DATA_E</VT>
                            </COMPU-CONST>
                          </COMPU-SCALE>
                          <COMPU-SCALE>
                            <DESC>
                              <L-2 L="EN">(Priority 10) Send ACK for the data in the next main function</L-2>
                            </DESC>
                            <LOWER-LIMIT INTERVAL-TYPE="CLOSED">10</LOWER-LIMIT>
                            <UPPER-LIMIT INTERVAL-TYPE="CLOSED">10</UPPER-LIMIT>
                            <COMPU-CONST>
                              <VT>RBA_ETHTCP_SEND_ACK_E</VT>
                            </COMPU-CONST>
                          </COMPU-SCALE>
                          <COMPU-SCALE>
                            <DESC>
                              <L-2 L="EN">(Priority 11) Send a Keep Alive in the next main function</L-2>
                            </DESC>
                            <LOWER-LIMIT INTERVAL-TYPE="CLOSED">11</LOWER-LIMIT>
                            <UPPER-LIMIT INTERVAL-TYPE="CLOSED">11</UPPER-LIMIT>
                            <COMPU-CONST>
                              <VT>RBA_ETHTCP_SEND_KEEP_ALIVE_E</VT>
                            </COMPU-CONST>
                          </COMPU-SCALE>
                        </COMPU-SCALES>
                      </COMPU-INTERNAL-TO-PHYS>
                    </COMPU-METHOD>
