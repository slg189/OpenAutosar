                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>
                      </ARGUMENTS>
                    </BSW-MODULE-ENTRY>
                    <BSW-MODULE-ENTRY>
                      <SHORT-NAME>rba_EthTcp_ChangeParameter</SHORT-NAME>
                      <DESC>
                        <L-2 L="EN">By this API, the rba_EthTcp module is requested to change a parameter of a socket. E.g. the Nagle algorithm may be controlled by this API</L-2>
                      </DESC>
                      <SERVICE-ID>4</SERVICE-ID>
                      <IS-REENTRANT>false</IS-REENTRANT>
                      <IS-SYNCHRONOUS>false</IS-SYNCHRONOUS>
