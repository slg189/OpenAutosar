                      </ARGUMENTS>
                    </BSW-MODULE-ENTRY>
                    <BSW-MODULE-ENTRY>
                      <SHORT-NAME>rba_EthTcp_Connect</SHORT-NAME>
                      <DESC>
                        <L-2 L="EN">By this API, the rba_EthTcp module is requested to establish a TCP connection to the configured peer</L-2>
                      </DESC>
                      <SERVICE-ID>5</SERVICE-ID>
                      <IS-REENTRANT>false</IS-REENTRANT>
