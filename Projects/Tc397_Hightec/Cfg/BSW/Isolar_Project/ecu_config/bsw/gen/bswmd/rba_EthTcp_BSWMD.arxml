                    <BSW-MODULE-ENTRY>
                      <SHORT-NAME>rba_EthTcp_AbortByLocalAddrId</SHORT-NAME>
                      <DESC>
                        <L-2 L="EN">By this API, Tcp is requested to terminate the connection using local address id</L-2>
                      </DESC>
                      <SERVICE-ID>13</SERVICE-ID>
                      <IS-REENTRANT>false</IS-REENTRANT>
                      <IS-SYNCHRONOUS>false</IS-SYNCHRONOUS>
                      <CALL-TYPE>REGULAR</CALL-TYPE>
                      <EXECUTION-CONTEXT>UNSPECIFIED</EXECUTION-CONTEXT>
                      <SW-SERVICE-IMPL-POLICY>STANDARD</SW-SERVICE-IMPL-POLICY>
                      <ARGUMENTS>
                        <SW-SERVICE-ARG>
                          <SHORT-NAME>LocalAddrId_u8</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Local address id</L-2>
                          </DESC>
                          <CATEGORY>TYPE_REFERENCE</CATEGORY>
                          <DIRECTION>IN</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>
                                <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_TcpIp/ImplementationDataTypes/TcpIp_LocalAddrIdType</IMPLEMENTATION-DATA-TYPE-REF>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>
                      </ARGUMENTS>
                    </BSW-MODULE-ENTRY>
                    <BSW-MODULE-ENTRY>
                      <SHORT-NAME>rba_EthTcp_Bind</SHORT-NAME>
                      <DESC>
                        <L-2 L="EN">By this API service the TCP/IP stack is requested to bind a TCP socket to a local resource</L-2>
                      </DESC>
                      <SERVICE-ID>11</SERVICE-ID>
                      <IS-REENTRANT>false</IS-REENTRANT>
                      <IS-SYNCHRONOUS>false</IS-SYNCHRONOUS>
                      <CALL-TYPE>REGULAR</CALL-TYPE>
                      <EXECUTION-CONTEXT>UNSPECIFIED</EXECUTION-CONTEXT>
                      <SW-SERVICE-IMPL-POLICY>STANDARD</SW-SERVICE-IMPL-POLICY>
                      <ARGUMENTS>
                        <SW-SERVICE-ARG>
                          <SHORT-NAME>TcpSockId_uo</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Tcp socket id</L-2>
                          </DESC>
                          <CATEGORY>TYPE_REFERENCE</CATEGORY>
                          <DIRECTION>IN</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>
                                <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_TcpIp/ImplementationDataTypes/TcpIp_SocketIdType</IMPLEMENTATION-DATA-TYPE-REF>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>
                        <SW-SERVICE-ARG>
                          <SHORT-NAME>LocalAddrId_u8</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Local address identifier representing the local IP address and EthIf controller to bind the socket to</L-2>
                          </DESC>
                          <CATEGORY>TYPE_REFERENCE</CATEGORY>
                          <DIRECTION>IN</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>
                                <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_TcpIp/ImplementationDataTypes/TcpIp_LocalAddrIdType</IMPLEMENTATION-DATA-TYPE-REF>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>
                        <SW-SERVICE-ARG>
                          <SHORT-NAME>PortPtr_pu16</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Local port to which the socket shall be bound.</L-2>
                          </DESC>
                          <CATEGORY>DATA_REFERENCE</CATEGORY>
                          <DIRECTION>OUT</DIRECTION>
