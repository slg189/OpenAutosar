                  </ELEMENTS>
                </AR-PACKAGE>
                <AR-PACKAGE>
                  <SHORT-NAME>BswModuleEntrys</SHORT-NAME>
                  <ELEMENTS>
                    <BSW-MODULE-ENTRY>
                      <SHORT-NAME>rba_EthUdp_Init</SHORT-NAME>
                      <LONG-NAME>
                        <L-4 L="EN">This function initializes the rba_EthUdp module.</L-4>
                      </LONG-NAME>
                      <DESC>
                        <L-2 L="EN">This function initializes the rba_EthUdp module.</L-2>
                      </DESC>
                      <IS-REENTRANT>false</IS-REENTRANT>
                      <IS-SYNCHRONOUS>true</IS-SYNCHRONOUS>
                      <CALL-TYPE>REGULAR</CALL-TYPE>
                      <EXECUTION-CONTEXT>UNSPECIFIED</EXECUTION-CONTEXT>
                      <SW-SERVICE-IMPL-POLICY>STANDARD</SW-SERVICE-IMPL-POLICY>
                      <ARGUMENTS>
                        <SW-SERVICE-ARG>
                          <SHORT-NAME>CurrConfig_pcst</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Configuration data structure for rba_EthUdp module.</L-2>
                          </DESC>
                          <CATEGORY>DATA_REFERENCE</CATEGORY>
                          <DIRECTION>IN</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>
                                <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                                <SW-POINTER-TARGET-PROPS>
                                  <TARGET-CATEGORY>VALUE</TARGET-CATEGORY>
                                  <SW-DATA-DEF-PROPS>
                                    <SW-DATA-DEF-PROPS-VARIANTS>
                                      <SW-DATA-DEF-PROPS-CONDITIONAL>
                                        <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/RB/RBA/rba_EthUdp/ImplementationDataTypes/rba_EthUdp_Config_to</IMPLEMENTATION-DATA-TYPE-REF>
                                        <SW-IMPL-POLICY>CONST</SW-IMPL-POLICY>
                                      </SW-DATA-DEF-PROPS-CONDITIONAL>
                                    </SW-DATA-DEF-PROPS-VARIANTS>
                                  </SW-DATA-DEF-PROPS>
                                </SW-POINTER-TARGET-PROPS>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>
                      </ARGUMENTS>
                    </BSW-MODULE-ENTRY>
                    <BSW-MODULE-ENTRY>
                      <SHORT-NAME>rba_EthUdp_ProvideTxBuffer</SHORT-NAME>
                      <LONG-NAME>
                        <L-4 L="EN">This service provides access to a transmit buffer.</L-4>
                      </LONG-NAME>
                      <DESC>
                        <L-2 L="EN">This function is called from TcpIp component to UDP layer to provide buffer to copy payload and then transmit this data by calling rba_EthUdp_Transmit(). rba_EthUdp adds the UDP header length before requesting for buffer.</L-2>
                      </DESC>
                      <IS-REENTRANT>true</IS-REENTRANT>
                      <IS-SYNCHRONOUS>true</IS-SYNCHRONOUS>
                      <CALL-TYPE>REGULAR</CALL-TYPE>
                      <EXECUTION-CONTEXT>UNSPECIFIED</EXECUTION-CONTEXT>
                      <SW-SERVICE-IMPL-POLICY>STANDARD</SW-SERVICE-IMPL-POLICY>
                      <RETURN-TYPE>
                        <SHORT-NAME>ReturnValue</SHORT-NAME>
                        <DESC>
                          <L-2 L="EN">Returns BUFREQ_OK if buffer allocation is successful. Returns BUFREQ_E_NOT_OK if development error is detected. Returns BUFREQ_E_BUSY if all buffers are in use. Returns BUFREQ_E_OVFL if requested length is greater than the available buffer length.</L-2>
                        </DESC>
                        <CATEGORY>TYPE_REFERENCE</CATEGORY>
                        <DIRECTION>OUT</DIRECTION>
                        <SW-DATA-DEF-PROPS>
                          <SW-DATA-DEF-PROPS-VARIANTS>
                            <SW-DATA-DEF-PROPS-CONDITIONAL>
                              <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_Comtype/ImplementationDataTypes/BufReq_ReturnType</IMPLEMENTATION-DATA-TYPE-REF>
                              <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                            </SW-DATA-DEF-PROPS-CONDITIONAL>
                          </SW-DATA-DEF-PROPS-VARIANTS>
                        </SW-DATA-DEF-PROPS>
                      </RETURN-TYPE>
                      <ARGUMENTS>
                        <SW-SERVICE-ARG>
                          <SHORT-NAME>SocketId_u16</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Socket id on which data is to be transmitted.</L-2>
                          </DESC>
                          <CATEGORY>TYPE_REFERENCE</CATEGORY>
                          <DIRECTION>IN</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>
                                <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_TcpIp/ImplementationDataTypes/TcpIp_SocketIdType</IMPLEMENTATION-DATA-TYPE-REF>
                                <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>
                        <SW-SERVICE-ARG>
                          <SHORT-NAME>DestIPv4Addr_u32</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">IP address of the destination node to which this node wants to transmit data.</L-2>
                          </DESC>
                          <CATEGORY>TYPE_REFERENCE</CATEGORY>
                          <DIRECTION>IN</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>
                                <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_Platform/ImplementationDataTypes/uint32</IMPLEMENTATION-DATA-TYPE-REF>
                                <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>
                        <SW-SERVICE-ARG>
                          <SHORT-NAME>BufIdx_pu8</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Index to the granted buffer resource. This shall be used during transmit request.</L-2>
                          </DESC>
                          <CATEGORY>DATA_REFERENCE</CATEGORY>
                          <DIRECTION>OUT</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>
                                <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                                <SW-POINTER-TARGET-PROPS>
                                  <TARGET-CATEGORY>VALUE</TARGET-CATEGORY>
                                  <SW-DATA-DEF-PROPS>
                                    <SW-DATA-DEF-PROPS-VARIANTS>
                                      <SW-DATA-DEF-PROPS-CONDITIONAL>
                                        <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_Platform/ImplementationDataTypes/uint8</IMPLEMENTATION-DATA-TYPE-REF>
                                        <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                                      </SW-DATA-DEF-PROPS-CONDITIONAL>
                                    </SW-DATA-DEF-PROPS-VARIANTS>
                                  </SW-DATA-DEF-PROPS>
                                </SW-POINTER-TARGET-PROPS>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>
                        <SW-SERVICE-ARG>
                          <SHORT-NAME>Buffer_ppu8</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Pointer to the granted buffer. A double pointer shall be passed and the address of the granted buffer shall be updated into this.</L-2>
                          </DESC>
                          <CATEGORY>DATA_REFERENCE</CATEGORY>
                          <DIRECTION>OUT</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>
                                <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                                <SW-POINTER-TARGET-PROPS>
                                  <TARGET-CATEGORY>VALUE</TARGET-CATEGORY>
                                  <SW-DATA-DEF-PROPS>
                                    <SW-DATA-DEF-PROPS-VARIANTS>
                                      <SW-DATA-DEF-PROPS-CONDITIONAL>
                                        <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_Platform/ImplementationDataTypes/uint8</IMPLEMENTATION-DATA-TYPE-REF>
                                        <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                                      </SW-DATA-DEF-PROPS-CONDITIONAL>
                                    </SW-DATA-DEF-PROPS-VARIANTS>
                                  </SW-DATA-DEF-PROPS>
                                </SW-POINTER-TARGET-PROPS>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>
                        <SW-SERVICE-ARG>
                          <SHORT-NAME>GrantLength_pcu16</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Requested buffer length. The lower layer can give a smaller buffer than requested.</L-2>
                          </DESC>
                          <CATEGORY>DATA_REFERENCE</CATEGORY>
                          <DIRECTION>INOUT</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>
                                <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                                <SW-POINTER-TARGET-PROPS>
                                  <TARGET-CATEGORY>VALUE</TARGET-CATEGORY>
                                  <SW-DATA-DEF-PROPS>
                                    <SW-DATA-DEF-PROPS-VARIANTS>
                                      <SW-DATA-DEF-PROPS-CONDITIONAL>
                                        <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_Platform/ImplementationDataTypes/uint16</IMPLEMENTATION-DATA-TYPE-REF>
                                        <SW-IMPL-POLICY>CONST</SW-IMPL-POLICY>
                                      </SW-DATA-DEF-PROPS-CONDITIONAL>
                                    </SW-DATA-DEF-PROPS-VARIANTS>
                                  </SW-DATA-DEF-PROPS>
                                </SW-POINTER-TARGET-PROPS>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>
                      </ARGUMENTS>
                    </BSW-MODULE-ENTRY>
                    <BSW-MODULE-ENTRY>
                      <SHORT-NAME>rba_EthUdp_RxIndication</SHORT-NAME>
                      <LONG-NAME>
                        <L-4 L="EN">This function is called from IP layer  to UDP layer after reception of a UDP datagram.</L-4>
                      </LONG-NAME>
                      <DESC>
                        <L-2 L="EN">This function is called from IPv4 or IPv6 components to UDP layer after reception of a UDP datagram.</L-2>
                      </DESC>
                      <IS-REENTRANT>true</IS-REENTRANT>
                      <IS-SYNCHRONOUS>true</IS-SYNCHRONOUS>
                      <CALL-TYPE>CALLBACK</CALL-TYPE>
                      <EXECUTION-CONTEXT>UNSPECIFIED</EXECUTION-CONTEXT>
                      <SW-SERVICE-IMPL-POLICY>STANDARD</SW-SERVICE-IMPL-POLICY>
                      <ARGUMENTS>
                        <SW-SERVICE-ARG>
                          <SHORT-NAME>PseudoHdr_pcst</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Pointer to pseudo header structure provided by IP layer. Contains protocol type, local and remote IP address, domain and IPv4 header length.</L-2>
                          </DESC>
                          <CATEGORY>DATA_REFERENCE</CATEGORY>
                          <DIRECTION>IN</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>
                                <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                                <SW-POINTER-TARGET-PROPS>
                                  <TARGET-CATEGORY>VALUE</TARGET-CATEGORY>
                                  <SW-DATA-DEF-PROPS>
                                    <SW-DATA-DEF-PROPS-VARIANTS>
                                      <SW-DATA-DEF-PROPS-CONDITIONAL>
                                        <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_TcpIp/ImplementationDataTypes/TcpIp_PseudoHdr_tst</IMPLEMENTATION-DATA-TYPE-REF>
                                        <SW-IMPL-POLICY>CONST</SW-IMPL-POLICY>
                                      </SW-DATA-DEF-PROPS-CONDITIONAL>
                                    </SW-DATA-DEF-PROPS-VARIANTS>
                                  </SW-DATA-DEF-PROPS>
                                </SW-POINTER-TARGET-PROPS>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>
                        <SW-SERVICE-ARG>
                          <SHORT-NAME>LocalAddrId_CtrlIdx_un</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Provides the local addrId or EthIf CtrlIdx (if broadcast ) of the received frame.</L-2>
                          </DESC>
                          <CATEGORY>TYPE_REFERENCE</CATEGORY>
                          <DIRECTION>IN</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>
                                <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_TcpIp/ImplementationDataTypes/TcpIp_LocalAddrId_EthIfCtrl_tun</IMPLEMENTATION-DATA-TYPE-REF>
                                <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>
                        <SW-SERVICE-ARG>
                          <SHORT-NAME>RxData_pu8</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Pointer to the received UDP datagram.</L-2>
                          </DESC>
                          <CATEGORY>DATA_REFERENCE</CATEGORY>
                          <DIRECTION>IN</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>
                                <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                                <SW-POINTER-TARGET-PROPS>
                                  <TARGET-CATEGORY>VALUE</TARGET-CATEGORY>
                                  <SW-DATA-DEF-PROPS>
                                    <SW-DATA-DEF-PROPS-VARIANTS>
                                      <SW-DATA-DEF-PROPS-CONDITIONAL>
                                        <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_Platform/ImplementationDataTypes/uint8</IMPLEMENTATION-DATA-TYPE-REF>
                                        <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                                      </SW-DATA-DEF-PROPS-CONDITIONAL>
                                    </SW-DATA-DEF-PROPS-VARIANTS>
                                  </SW-DATA-DEF-PROPS>
                                </SW-POINTER-TARGET-PROPS>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>
                        <SW-SERVICE-ARG>
                          <SHORT-NAME>RxDataLen_u16</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Length of the UDP datagram.</L-2>
                          </DESC>
                          <CATEGORY>TYPE_REFERENCE</CATEGORY>
                          <DIRECTION>IN</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>
                                <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_Platform/ImplementationDataTypes/uint16</IMPLEMENTATION-DATA-TYPE-REF>
                                <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>
                        <SW-SERVICE-ARG>
                          <SHORT-NAME>IsBroadcast_b</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Indicates whether received frame is IPv4 broadcast frame or not.</L-2>
                          </DESC>
                          <CATEGORY>TYPE_REFERENCE</CATEGORY>
                          <DIRECTION>IN</DIRECTION>
                          <SW-DATA-DEF-PROPS>
                            <SW-DATA-DEF-PROPS-VARIANTS>
                              <SW-DATA-DEF-PROPS-CONDITIONAL>
                                <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_Platform/ImplementationDataTypes/boolean</IMPLEMENTATION-DATA-TYPE-REF>
                                <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                              </SW-DATA-DEF-PROPS-CONDITIONAL>
                            </SW-DATA-DEF-PROPS-VARIANTS>
                          </SW-DATA-DEF-PROPS>
                        </SW-SERVICE-ARG>
                      </ARGUMENTS>
                    </BSW-MODULE-ENTRY>
                    <BSW-MODULE-ENTRY>
                      <SHORT-NAME>rba_EthUdp_Transmit</SHORT-NAME>
                      <LONG-NAME>
                        <L-4 L="EN">This service transmits data over UDP.</L-4>
                      </LONG-NAME>
                      <DESC>
                        <L-2 L="EN">This function is called from TcpIp component to transmit data over UDP. In this API UDP fills the UDP header and forwards a call to rba_EthIPv4 or rba_EthIPv6 module.</L-2>
                      </DESC>
                      <IS-REENTRANT>true</IS-REENTRANT>
                      <IS-SYNCHRONOUS>true</IS-SYNCHRONOUS>
                      <CALL-TYPE>REGULAR</CALL-TYPE>
                      <EXECUTION-CONTEXT>UNSPECIFIED</EXECUTION-CONTEXT>
                      <SW-SERVICE-IMPL-POLICY>STANDARD</SW-SERVICE-IMPL-POLICY>
                      <RETURN-TYPE>
                        <SHORT-NAME>ReturnValue</SHORT-NAME>
                        <DESC>
                          <L-2 L="EN">Returns TCPIP_OK if UDP datagram transmission successful. Returns TCPIP_E_NOT_OK if UDP datagram transmission failed (general failure). Returns TCPIP_E_ARP_CACHE_MISS if UDP datagram transmission failed because of ARP cache miss.</L-2>
                        </DESC>
                        <CATEGORY>TYPE_REFERENCE</CATEGORY>
                        <DIRECTION>OUT</DIRECTION>
                        <SW-DATA-DEF-PROPS>
                          <SW-DATA-DEF-PROPS-VARIANTS>
                            <SW-DATA-DEF-PROPS-CONDITIONAL>
                              <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_TcpIp/ImplementationDataTypes/TcpIp_ReturnType</IMPLEMENTATION-DATA-TYPE-REF>
                              <SW-IMPL-POLICY>STANDARD</SW-IMPL-POLICY>
                            </SW-DATA-DEF-PROPS-CONDITIONAL>
                          </SW-DATA-DEF-PROPS-VARIANTS>
                        </SW-DATA-DEF-PROPS>
                      </RETURN-TYPE>
                      <ARGUMENTS>
                        <SW-SERVICE-ARG>
                          <SHORT-NAME>SocketId_u16</SHORT-NAME>
