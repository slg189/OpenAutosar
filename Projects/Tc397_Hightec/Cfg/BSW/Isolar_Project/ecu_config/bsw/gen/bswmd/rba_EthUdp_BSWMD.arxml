                        </BSW-MODULE-ENTRY-REF-CONDITIONAL>
                        <BSW-MODULE-ENTRY-REF-CONDITIONAL>
                          <BSW-MODULE-ENTRY-REF DEST="BSW-MODULE-ENTRY">/RB/RBA/rba_EthUdp/BswModuleEntrys/rba_EthUdp_Bind</BSW-MODULE-ENTRY-REF>
                        </BSW-MODULE-ENTRY-REF-CONDITIONAL>
                        <BSW-MODULE-ENTRY-REF-CONDITIONAL>
                          <BSW-MODULE-ENTRY-REF DEST="BSW-MODULE-ENTRY">/RB/RBA/rba_EthUdp/BswModuleEntrys/rba_EthUdp_Close</BSW-MODULE-ENTRY-REF>
                        </BSW-MODULE-ENTRY-REF-CONDITIONAL>
                        <BSW-MODULE-ENTRY-REF-CONDITIONAL>
                          <BSW-MODULE-ENTRY-REF DEST="BSW-MODULE-ENTRY">/RB/RBA/rba_EthUdp/BswModuleEntrys/rba_EthUdp_ChangeParameter</BSW-MODULE-ENTRY-REF>
                        </BSW-MODULE-ENTRY-REF-CONDITIONAL>
                        <BSW-MODULE-ENTRY-REF-CONDITIONAL>
                          <BSW-MODULE-ENTRY-REF DEST="BSW-MODULE-ENTRY">/RB/RBA/rba_EthUdp/BswModuleEntrys/rba_EthUdp_GetSocketInfo</BSW-MODULE-ENTRY-REF>
                        </BSW-MODULE-ENTRY-REF-CONDITIONAL>
                        <BSW-MODULE-ENTRY-REF-CONDITIONAL>
                          <BSW-MODULE-ENTRY-REF DEST="BSW-MODULE-ENTRY">/RB/RBA/rba_EthUdp/BswModuleEntrys/rba_EthUdp_TerminateSocUsingLocalAddr</BSW-MODULE-ENTRY-REF>
                        </BSW-MODULE-ENTRY-REF-CONDITIONAL>
                        <BSW-MODULE-ENTRY-REF-CONDITIONAL>
                          <BSW-MODULE-ENTRY-REF DEST="BSW-MODULE-ENTRY">/RB/RBA/rba_EthUdp/BswModuleEntrys/rba_EthUdp_GetAndResetMeasurementData</BSW-MODULE-ENTRY-REF>
                        </BSW-MODULE-ENTRY-REF-CONDITIONAL>
                        <BSW-MODULE-ENTRY-REF-CONDITIONAL>
                          <BSW-MODULE-ENTRY-REF DEST="BSW-MODULE-ENTRY">/RB/RBA/rba_EthUdp/BswModuleEntrys/rba_EthUdp_MainFunction</BSW-MODULE-ENTRY-REF>
                        </BSW-MODULE-ENTRY-REF-CONDITIONAL>
                        <BSW-MODULE-ENTRY-REF-CONDITIONAL>
                          <BSW-MODULE-ENTRY-REF DEST="BSW-MODULE-ENTRY">/RB/RBA/rba_EthUdp/BswModuleEntrys/rba_EthUdp_CheckFragmentation</BSW-MODULE-ENTRY-REF>
                        </BSW-MODULE-ENTRY-REF-CONDITIONAL>
                        <BSW-MODULE-ENTRY-REF-CONDITIONAL>
                          <BSW-MODULE-ENTRY-REF DEST="BSW-MODULE-ENTRY">/RB/RBA/rba_EthUdp/BswModuleEntrys/rba_EthUdp_ZeroCopyFillHeader</BSW-MODULE-ENTRY-REF>
                        </BSW-MODULE-ENTRY-REF-CONDITIONAL>
                        <BSW-MODULE-ENTRY-REF-CONDITIONAL>
                          <BSW-MODULE-ENTRY-REF DEST="BSW-MODULE-ENTRY">/RB/RBA/rba_EthUdp/BswModuleEntrys/rba_EthUdp_ZeroCopyTransmit</BSW-MODULE-ENTRY-REF>
