                      <LONG-NAME>
                        <L-4 L="EN">rba_EthUdp_ZeroCopyFillHeader</L-4>
                      </LONG-NAME>
                      <DESC>
                        <L-2 L="EN">This API prefill the reusable part of the Udp header.</L-2>
                      </DESC>
                      <IS-REENTRANT>true</IS-REENTRANT>
                      <IS-SYNCHRONOUS>true</IS-SYNCHRONOUS>
                      <CALL-TYPE>REGULAR</CALL-TYPE>
