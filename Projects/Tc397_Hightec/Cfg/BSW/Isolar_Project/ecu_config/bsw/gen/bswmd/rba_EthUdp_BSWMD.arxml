                      <RETURN-TYPE>
                        <SHORT-NAME>ReturnValue</SHORT-NAME>
                        <DESC>
                          <L-2 L="EN">Returns TCPIP_OK if UDP datagram filling successful. Returns TCPIP_E_NOT_OK if UDP datagram filling failed (general failure). Returns TCPIP_E_ARP_CACHE_MISS if UDP datagram filling failed because of ARP cache miss.</L-2>
                        </DESC>
                        <CATEGORY>TYPE_REFERENCE</CATEGORY>
                        <DIRECTION>OUT</DIRECTION>
