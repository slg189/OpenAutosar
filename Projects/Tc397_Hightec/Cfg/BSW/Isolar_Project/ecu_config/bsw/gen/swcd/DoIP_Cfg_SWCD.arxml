<?xml version="1.0" encoding="UTF-8"?>
<AUTOSAR xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://autosar.org/schema/r4.0"
    xsi:schemaLocation="http://autosar.org/schema/r4.0 AUTOSAR_4-2-2.xsd">
  <AR-PACKAGES>
    <AR-PACKAGE>
      <SHORT-NAME>AUTOSAR_DoIP</SHORT-NAME>
      <AR-PACKAGES>
        <AR-PACKAGE>
          <SHORT-NAME>SwComponentTypes</SHORT-NAME>
          <ELEMENTS>
            <SERVICE-SW-COMPONENT-TYPE>
              <SHORT-NAME>DoIP</SHORT-NAME>
              <PORTS>
                <R-PORT-PROTOTYPE>
                  <SHORT-NAME>CBGetPowerMode</SHORT-NAME>
                  <REQUIRED-INTERFACE-TREF DEST="CLIENT-SERVER-INTERFACE">/AUTOSAR_DoIP/PortInterfaces/CallbackGetPowerMode</REQUIRED-INTERFACE-TREF>
                </R-PORT-PROTOTYPE>
                <R-PORT-PROTOTYPE>
                  <SHORT-NAME>DoIPActivationLineSwitchNotification</SHORT-NAME>
                  <REQUIRED-COM-SPECS>
                    <MODE-SWITCH-RECEIVER-COM-SPEC>
                      <SUPPORTS-ASYNCHRONOUS-MODE-SWITCH>true</SUPPORTS-ASYNCHRONOUS-MODE-SWITCH>
                    </MODE-SWITCH-RECEIVER-COM-SPEC>
                  </REQUIRED-COM-SPECS>
                  <REQUIRED-INTERFACE-TREF DEST="MODE-SWITCH-INTERFACE">/AUTOSAR_DoIP/ModeSwitchInterfaces/DoIPActivationLineStatus</REQUIRED-INTERFACE-TREF>
                </R-PORT-PROTOTYPE>
              </PORTS>
              <INTERNAL-BEHAVIORS>
                <SWC-INTERNAL-BEHAVIOR>
                  <SHORT-NAME>IntBeh_DoIP</SHORT-NAME>
                  <DATA-TYPE-MAPPING-REFS>
                    <DATA-TYPE-MAPPING-REF DEST="DATA-TYPE-MAPPING-SET">/AUTOSAR_DoIP/ImplementationDataTypes/DTS_DoIP_ActivationLineType</DATA-TYPE-MAPPING-REF>
                  </DATA-TYPE-MAPPING-REFS>
                  <EVENTS>
                    <SWC-MODE-SWITCH-EVENT>
                      <SHORT-NAME>SwcModeSwitchEvent_0</SHORT-NAME>
                      <START-ON-EVENT-REF DEST="RUNNABLE-ENTITY">/AUTOSAR_DoIP/SwComponentTypes/DoIP/IntBeh_DoIP/RunnableEntity_DoIPActivationLineActive</START-ON-EVENT-REF>
                      <ACTIVATION>ON-ENTRY</ACTIVATION>
                      <MODE-IREFS>
                        <MODE-IREF>
                          <CONTEXT-PORT-REF DEST="R-PORT-PROTOTYPE">/AUTOSAR_DoIP/SwComponentTypes/DoIP/DoIPActivationLineSwitchNotification</CONTEXT-PORT-REF>
                          <CONTEXT-MODE-DECLARATION-GROUP-PROTOTYPE-REF DEST="MODE-DECLARATION-GROUP-PROTOTYPE">/AUTOSAR_DoIP/ModeSwitchInterfaces/DoIPActivationLineStatus/currentDoIPActivationLineStatus</CONTEXT-MODE-DECLARATION-GROUP-PROTOTYPE-REF>
                          <TARGET-MODE-DECLARATION-REF DEST="MODE-DECLARATION">/AUTOSAR_DoIP/ModeDeclarationGroups/DoIP_ActivationLineType/DOIP_ACTIVATION_LINE_ACTIVE</TARGET-MODE-DECLARATION-REF>
                        </MODE-IREF>
                      </MODE-IREFS>
                    </SWC-MODE-SWITCH-EVENT>
                    <SWC-MODE-SWITCH-EVENT>
                      <SHORT-NAME>SwcModeSwitchEvent_1</SHORT-NAME>
                      <START-ON-EVENT-REF DEST="RUNNABLE-ENTITY">/AUTOSAR_DoIP/SwComponentTypes/DoIP/IntBeh_DoIP/RunnableEntity_DoIPActivationLineInactive</START-ON-EVENT-REF>
                      <ACTIVATION>ON-ENTRY</ACTIVATION>
                      <MODE-IREFS>
                        <MODE-IREF>
                          <CONTEXT-PORT-REF DEST="R-PORT-PROTOTYPE">/AUTOSAR_DoIP/SwComponentTypes/DoIP/DoIPActivationLineSwitchNotification</CONTEXT-PORT-REF>
                          <CONTEXT-MODE-DECLARATION-GROUP-PROTOTYPE-REF DEST="MODE-DECLARATION-GROUP-PROTOTYPE">/AUTOSAR_DoIP/ModeSwitchInterfaces/DoIPActivationLineStatus/currentDoIPActivationLineStatus</CONTEXT-MODE-DECLARATION-GROUP-PROTOTYPE-REF>
                          <TARGET-MODE-DECLARATION-REF DEST="MODE-DECLARATION">/AUTOSAR_DoIP/ModeDeclarationGroups/DoIP_ActivationLineType/DOIP_ACTIVATION_LINE_INACTIVE</TARGET-MODE-DECLARATION-REF>
                        </MODE-IREF>
                      </MODE-IREFS>
                    </SWC-MODE-SWITCH-EVENT>
                  </EVENTS>
                  <INCLUDED-DATA-TYPE-SETS>
                    <INCLUDED-DATA-TYPE-SET>
                      <DATA-TYPE-REFS>
                        <DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_DoIP/ImplementationDataTypes/DoIP_ActivationLineRequestType</DATA-TYPE-REF>
                      </DATA-TYPE-REFS>
                    </INCLUDED-DATA-TYPE-SET>
                  </INCLUDED-DATA-TYPE-SETS>
                  <PORT-API-OPTIONS>
                    <PORT-API-OPTION>
                      <ENABLE-TAKE-ADDRESS>true</ENABLE-TAKE-ADDRESS>
                      <INDIRECT-API>false</INDIRECT-API>
                      <PORT-REF DEST="R-PORT-PROTOTYPE">/AUTOSAR_DoIP/SwComponentTypes/DoIP/CBGetPowerMode</PORT-REF>
                    </PORT-API-OPTION>
                  </PORT-API-OPTIONS>
                  <RUNNABLES>
                    <RUNNABLE-ENTITY>
                      <SHORT-NAME>DoIP_MainFunction</SHORT-NAME>
                      <CAN-BE-INVOKED-CONCURRENTLY>false</CAN-BE-INVOKED-CONCURRENTLY>
                      <SERVER-CALL-POINTS>
                        <SYNCHRONOUS-SERVER-CALL-POINT>
                          <SHORT-NAME>SSC_GetPowerMode</SHORT-NAME>
                          <OPERATION-IREF>
                            <CONTEXT-R-PORT-REF DEST="R-PORT-PROTOTYPE">/AUTOSAR_DoIP/SwComponentTypes/DoIP/CBGetPowerMode</CONTEXT-R-PORT-REF>
                            <TARGET-REQUIRED-OPERATION-REF DEST="CLIENT-SERVER-OPERATION">/AUTOSAR_DoIP/PortInterfaces/CallbackGetPowerMode/GetPowerMode</TARGET-REQUIRED-OPERATION-REF>
                          </OPERATION-IREF>
                        </SYNCHRONOUS-SERVER-CALL-POINT>
                      </SERVER-CALL-POINTS>
                      <SYMBOL>DoIP_MainFunction</SYMBOL>
                    </RUNNABLE-ENTITY>
                    <RUNNABLE-ENTITY>
                      <SHORT-NAME>RunnableEntity_DoIPActivationLineActive</SHORT-NAME>
                      <CAN-BE-INVOKED-CONCURRENTLY>true</CAN-BE-INVOKED-CONCURRENTLY>
                      <SYMBOL>DoIP_ActivationLineSwitchActive</SYMBOL>
                    </RUNNABLE-ENTITY>
                    <RUNNABLE-ENTITY>
                      <SHORT-NAME>RunnableEntity_DoIPActivationLineInactive</SHORT-NAME>
                      <CAN-BE-INVOKED-CONCURRENTLY>true</CAN-BE-INVOKED-CONCURRENTLY>
                      <SYMBOL>DoIP_ActivationLineSwitchInactive</SYMBOL>
                    </RUNNABLE-ENTITY>
                  </RUNNABLES>
                </SWC-INTERNAL-BEHAVIOR>
              </INTERNAL-BEHAVIORS>
            </SERVICE-SW-COMPONENT-TYPE>
          </ELEMENTS>
        </AR-PACKAGE>
        <AR-PACKAGE>
          <SHORT-NAME>CompuMethods</SHORT-NAME>
          <ELEMENTS>
            <COMPU-METHOD>
              <SHORT-NAME>DoIP_ActivationLineRequestType_Values</SHORT-NAME>
              <CATEGORY>TEXTTABLE</CATEGORY>
              <COMPU-INTERNAL-TO-PHYS>
                <COMPU-SCALES>
                  <COMPU-SCALE>
                    <SHORT-LABEL>DOIP_ACTIVATION_LINE_ACTIVE</SHORT-LABEL>
                    <LOWER-LIMIT BINDING-TIME="SYSTEM-DESIGN-TIME" SHORT-LABEL="DOIP_ACTIVATION_LINE_ACTIVE">1</LOWER-LIMIT>
                    <UPPER-LIMIT BINDING-TIME="SYSTEM-DESIGN-TIME" SHORT-LABEL="DOIP_ACTIVATION_LINE_ACTIVE">1</UPPER-LIMIT>
                    <COMPU-CONST>
                      <VT>DOIP_ACTIVATION_LINE_ACTIVE</VT>
                    </COMPU-CONST>
                  </COMPU-SCALE>
                  <COMPU-SCALE>
                    <SHORT-LABEL>DOIP_ACTIVATION_LINE_INACTIVE</SHORT-LABEL>
                    <LOWER-LIMIT BINDING-TIME="SYSTEM-DESIGN-TIME" SHORT-LABEL="DOIP_ACTIVATION_LINE_INACTIVE">0</LOWER-LIMIT>
                    <UPPER-LIMIT BINDING-TIME="SYSTEM-DESIGN-TIME" SHORT-LABEL="DOIP_ACTIVATION_LINE_INACTIVE">0</UPPER-LIMIT>
                    <COMPU-CONST>
                      <VT>DOIP_ACTIVATION_LINE_INACTIVE</VT>
                    </COMPU-CONST>
                  </COMPU-SCALE>
                </COMPU-SCALES>
              </COMPU-INTERNAL-TO-PHYS>
            </COMPU-METHOD>
            <COMPU-METHOD>
              <SHORT-NAME>DoIP_PowerStateTypeValues</SHORT-NAME>
              <CATEGORY>TEXTTABLE</CATEGORY>
              <COMPU-INTERNAL-TO-PHYS>
                <COMPU-SCALES>
                  <COMPU-SCALE>
                    <SHORT-LABEL>DOIP_NOT_READY</SHORT-LABEL>
                    <LOWER-LIMIT BINDING-TIME="SYSTEM-DESIGN-TIME" SHORT-LABEL="DOIP_NOT_READY">0</LOWER-LIMIT>
                    <UPPER-LIMIT BINDING-TIME="SYSTEM-DESIGN-TIME" SHORT-LABEL="DOIP_NOT_READY">0</UPPER-LIMIT>
                    <COMPU-CONST>
                      <VT>DOIP_NOT_READY</VT>
                    </COMPU-CONST>
                  </COMPU-SCALE>
                  <COMPU-SCALE>
                    <SHORT-LABEL>DOIP_READY</SHORT-LABEL>
                    <LOWER-LIMIT BINDING-TIME="SYSTEM-DESIGN-TIME" SHORT-LABEL="DOIP_READY">1</LOWER-LIMIT>
                    <UPPER-LIMIT BINDING-TIME="SYSTEM-DESIGN-TIME" SHORT-LABEL="DOIP_READY">1</UPPER-LIMIT>
                    <COMPU-CONST>
                      <VT>DOIP_READY</VT>
                    </COMPU-CONST>
                  </COMPU-SCALE>
                  <COMPU-SCALE>
                    <SHORT-LABEL>DOIP_NOT_SUPPORTED</SHORT-LABEL>
                    <LOWER-LIMIT BINDING-TIME="SYSTEM-DESIGN-TIME" SHORT-LABEL="DOIP_NOT_SUPPORTED">2</LOWER-LIMIT>
                    <UPPER-LIMIT BINDING-TIME="SYSTEM-DESIGN-TIME" SHORT-LABEL="DOIP_NOT_SUPPORTED">2</UPPER-LIMIT>
                    <COMPU-CONST>
                      <VT>DOIP_NOT_SUPPORTED</VT>
                    </COMPU-CONST>
                  </COMPU-SCALE>
                </COMPU-SCALES>
              </COMPU-INTERNAL-TO-PHYS>
            </COMPU-METHOD>
          </ELEMENTS>
        </AR-PACKAGE>
        <AR-PACKAGE>
          <SHORT-NAME>ImplementationDataTypes</SHORT-NAME>
          <ELEMENTS>
            <IMPLEMENTATION-DATA-TYPE>
              <SHORT-NAME>DoIP_ActivationLineRequestType</SHORT-NAME>
              <CATEGORY>TYPE_REFERENCE</CATEGORY>
              <SW-DATA-DEF-PROPS>
                <SW-DATA-DEF-PROPS-VARIANTS>
                  <SW-DATA-DEF-PROPS-CONDITIONAL>
                    <COMPU-METHOD-REF DEST="COMPU-METHOD">/AUTOSAR_DoIP/CompuMethods/DoIP_ActivationLineRequestType_Values</COMPU-METHOD-REF>
                    <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_Platform/ImplementationDataTypes/uint8</IMPLEMENTATION-DATA-TYPE-REF>
                  </SW-DATA-DEF-PROPS-CONDITIONAL>
                </SW-DATA-DEF-PROPS-VARIANTS>
              </SW-DATA-DEF-PROPS>
            </IMPLEMENTATION-DATA-TYPE>
            <IMPLEMENTATION-DATA-TYPE>
              <SHORT-NAME>DoIP_PowerStateType</SHORT-NAME>
              <CATEGORY>TYPE_REFERENCE</CATEGORY>
              <SW-DATA-DEF-PROPS>
                <SW-DATA-DEF-PROPS-VARIANTS>
                  <SW-DATA-DEF-PROPS-CONDITIONAL>
                    <COMPU-METHOD-REF DEST="COMPU-METHOD">/AUTOSAR_DoIP/CompuMethods/DoIP_PowerStateTypeValues</COMPU-METHOD-REF>
                    <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_Platform/ImplementationDataTypes/uint8</IMPLEMENTATION-DATA-TYPE-REF>
                  </SW-DATA-DEF-PROPS-CONDITIONAL>
                </SW-DATA-DEF-PROPS-VARIANTS>
              </SW-DATA-DEF-PROPS>
            </IMPLEMENTATION-DATA-TYPE>
            <DATA-TYPE-MAPPING-SET>
              <SHORT-NAME>DTS_DoIP_ActivationLineType</SHORT-NAME>
              <MODE-REQUEST-TYPE-MAPS>
                <MODE-REQUEST-TYPE-MAP>
                  <IMPLEMENTATION-DATA-TYPE-REF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_DoIP/ImplementationDataTypes/DoIP_ActivationLineRequestType</IMPLEMENTATION-DATA-TYPE-REF>
                  <MODE-GROUP-REF DEST="MODE-DECLARATION-GROUP">/AUTOSAR_DoIP/ModeDeclarationGroups/DoIP_ActivationLineType</MODE-GROUP-REF>
                </MODE-REQUEST-TYPE-MAP>
              </MODE-REQUEST-TYPE-MAPS>
            </DATA-TYPE-MAPPING-SET>
          </ELEMENTS>
        </AR-PACKAGE>
        <AR-PACKAGE>
          <SHORT-NAME>SwcImplementations</SHORT-NAME>
          <ELEMENTS>
            <SWC-IMPLEMENTATION>
              <SHORT-NAME>Impl_DoIP</SHORT-NAME>
              <CODE-DESCRIPTORS>
                <CODE>
                  <SHORT-NAME>CodeDescr_DoIP</SHORT-NAME>
                  <ARTIFACT-DESCRIPTORS>
                    <AUTOSAR-ENGINEERING-OBJECT>
                      <SHORT-LABEL>Code_0</SHORT-LABEL>
                      <CATEGORY>SWSRC</CATEGORY>
                    </AUTOSAR-ENGINEERING-OBJECT>
                  </ARTIFACT-DESCRIPTORS>
                </CODE>
              </CODE-DESCRIPTORS>
              <PROGRAMMING-LANGUAGE>C</PROGRAMMING-LANGUAGE>
              <SW-VERSION>9.0.0</SW-VERSION>
              <VENDOR-ID>6</VENDOR-ID>
              <BEHAVIOR-REF DEST="SWC-INTERNAL-BEHAVIOR">/AUTOSAR_DoIP/SwComponentTypes/DoIP/IntBeh_DoIP</BEHAVIOR-REF>
            </SWC-IMPLEMENTATION>
          </ELEMENTS>
        </AR-PACKAGE>
        <AR-PACKAGE>
          <SHORT-NAME>PortInterfaces</SHORT-NAME>
          <ELEMENTS>
            <CLIENT-SERVER-INTERFACE>
              <SHORT-NAME>CallbackGetPowerMode</SHORT-NAME>
              <IS-SERVICE>true</IS-SERVICE>
              <OPERATIONS>
                <CLIENT-SERVER-OPERATION>
                  <SHORT-NAME>GetPowerMode</SHORT-NAME>
                  <ARGUMENTS>
                    <ARGUMENT-DATA-PROTOTYPE>
                      <SHORT-NAME>PowerStateReady</SHORT-NAME>
                      <TYPE-TREF DEST="IMPLEMENTATION-DATA-TYPE">/AUTOSAR_DoIP/ImplementationDataTypes/DoIP_PowerStateType</TYPE-TREF>
                      <DIRECTION>OUT</DIRECTION>
                    </ARGUMENT-DATA-PROTOTYPE>
                  </ARGUMENTS>
                  <POSSIBLE-ERROR-REFS>
                    <POSSIBLE-ERROR-REF DEST="APPLICATION-ERROR">/AUTOSAR_DoIP/PortInterfaces/CallbackGetPowerMode/E_OK</POSSIBLE-ERROR-REF>
                    <POSSIBLE-ERROR-REF DEST="APPLICATION-ERROR">/AUTOSAR_DoIP/PortInterfaces/CallbackGetPowerMode/E_NOT_OK</POSSIBLE-ERROR-REF>
                  </POSSIBLE-ERROR-REFS>
                </CLIENT-SERVER-OPERATION>
              </OPERATIONS>
              <POSSIBLE-ERRORS>
                <APPLICATION-ERROR>
                  <SHORT-NAME>E_OK</SHORT-NAME>
                  <ERROR-CODE>0</ERROR-CODE>
                </APPLICATION-ERROR>
                <APPLICATION-ERROR>
                  <SHORT-NAME>E_NOT_OK</SHORT-NAME>
                  <ERROR-CODE>1</ERROR-CODE>
                </APPLICATION-ERROR>
              </POSSIBLE-ERRORS>
            </CLIENT-SERVER-INTERFACE>
          </ELEMENTS>
        </AR-PACKAGE>
        <AR-PACKAGE>
          <SHORT-NAME>ModeDeclarationGroups</SHORT-NAME>
          <ELEMENTS>
            <MODE-DECLARATION-GROUP>
              <SHORT-NAME>DoIP_ActivationLineType</SHORT-NAME>
              <CATEGORY>EXPLICIT_ORDER</CATEGORY>
              <INITIAL-MODE-REF DEST="MODE-DECLARATION">/AUTOSAR_DoIP/ModeDeclarationGroups/DoIP_ActivationLineType/DOIP_ACTIVATION_LINE_INACTIVE</INITIAL-MODE-REF>
              <MODE-DECLARATIONS>
                <MODE-DECLARATION>
                  <SHORT-NAME>DOIP_ACTIVATION_LINE_ACTIVE</SHORT-NAME>
                  <VALUE>1</VALUE>
                </MODE-DECLARATION>
                <MODE-DECLARATION>
                  <SHORT-NAME>DOIP_ACTIVATION_LINE_INACTIVE</SHORT-NAME>
                  <VALUE>0</VALUE>
                </MODE-DECLARATION>
              </MODE-DECLARATIONS>
              <ON-TRANSITION-VALUE>2</ON-TRANSITION-VALUE>
            </MODE-DECLARATION-GROUP>
          </ELEMENTS>
        </AR-PACKAGE>
        <AR-PACKAGE>
          <SHORT-NAME>ModeSwitchInterfaces</SHORT-NAME>
          <ELEMENTS>
            <MODE-SWITCH-INTERFACE>
              <SHORT-NAME>DoIPActivationLineStatus</SHORT-NAME>
              <MODE-GROUP>
                <SHORT-NAME>currentDoIPActivationLineStatus</SHORT-NAME>
                <TYPE-TREF DEST="MODE-DECLARATION-GROUP">/AUTOSAR_DoIP/ModeDeclarationGroups/DoIP_ActivationLineType</TYPE-TREF>
              </MODE-GROUP>
            </MODE-SWITCH-INTERFACE>
          </ELEMENTS>
        </AR-PACKAGE>
      </AR-PACKAGES>
    </AR-PACKAGE>
  </AR-PACKAGES>
</AUTOSAR>
