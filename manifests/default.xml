<?xml version="1.0" encoding="UTF-8"?>
<!-- ============================================================================
     default.xml — 完整视图 (平台/集成负责人): 拥有所有层源码 + 全部库
     ============================================================================
     子库划分原则:
       - 共享源码: MCAL 静态源码(供应商, 静态与配置分离, 跨项目复用) 及
                   Components / Projects / Tools 各建一个子库
                   (Test / Docs / Reports 已随工程下沉到 Projects/<P>/, 属 projects 子库)
       - BSW 供应商交付: 不再分 Vector/Etas 目录, 仅按模块名组织; 供应商/芯片/交付版本
                 编码进子库名 (BSW_<Vendor>_<Chip>_<Delivery>), 归 BSW group, 每家供应商
                 一个交付库, 各自检出到 BSW/<模块> —— 共同组成扁平的 BSW/ 树。
       - 项目源码: ASW / CDD 模块代码未按 AUTOSAR 静态/配置分离, 整体与项目相关,
                   故源码也按项目: asw_<project> / cdd_<project> (检出到 ASW / CDD)
       - 项目库: ASW_Libs / CDD_Libs / BSW_Libs / MCAL_Libs 全部与项目相关,
                 各按项目建一个子库 (MCAL 配置代码与静态代码一并编译链接为库;
                 BSW 的 .a 也已把项目配置代码打包)。
                 仓库名 <layer>_libs_<project> (扁平/下划线); 项目身份在仓库名中,
                 故检出路径直接是 <Layer>_Libs (不带项目子目录, 拉取时项目已确定)。
     一个工作区对应一个项目; 切换项目 = 换一套 *_<Proj> / *_libs_<Proj> 子库即可。
     ============================================================================ -->
<manifest>
  <remote name="origin" fetch="ssh://git@example.com/autosar/"/>
  <default remote="origin" revision="main" sync-j="8"/>

  <!-- ===== 项目源码子库 (ASW / CDD 按项目) ===== -->
  <project name="asw_Demo_Tc387.git" path="ASW"  groups="src,asw,proj_Demo_Tc387"/>
  <project name="cdd_Demo_Tc387.git" path="CDD"  groups="src,cdd,proj_Demo_Tc387"/>

  <!-- ===== 共享源码子库 (静态/配置分离, 跨项目复用) =====
       Test / Docs / Reports 已并入 Projects (projects 子库)。 -->
  <project name="mcal.git"       path="MCAL"        groups="src,mcal"/>
  <project name="components.git" path="Components"  groups="src"/>
  <project name="projects.git"   path="Projects"    groups="src,integration"/>
  <project name="tools.git"      path="Tools"       groups="src,tools"/>

  <!-- ===== BSW 供应商交付子库 (BSW group; 按模块名检出, 组成扁平 BSW/ 树) =====
       子库名编码 供应商/芯片/交付版本; 交付版本(如 CBDxxxxxx)按实际交付改名。 -->
  <project name="BSW_Common_TC387.git"         path="BSW/inc" groups="src,bsw"/>
  <project name="BSW_Etas_TC387_RtaOs.git"     path="BSW/Os"  groups="src,bsw"/>
  <project name="BSW_Vector_TC387_CBDxxxxxx.git" path="BSW/Com" groups="src,bsw"/>

  <!-- ===== 项目库子库 (ASW / CDD / BSW / MCAL 全部按项目; 检出到 <Layer>_Libs 根) =====
       本工作区对应项目 Demo_Tc387 -->
  <project name="asw_libs_Demo_Tc387.git"  path="ASW_Libs"  groups="libs,asw_libs,proj_Demo_Tc387"/>
  <project name="cdd_libs_Demo_Tc387.git"  path="CDD_Libs"  groups="libs,cdd_libs,proj_Demo_Tc387"/>
  <project name="bsw_libs_Demo_Tc387.git"  path="BSW_Libs"  groups="libs,bsw_libs,proj_Demo_Tc387"/>
  <project name="mcal_libs_Demo_Tc387.git" path="MCAL_Libs" groups="libs,mcal_libs,proj_Demo_Tc387"/>

  <!-- ===== 元信息子库 (清单 + 根脚本/配置) =====
       检出到 .meta 子目录 (避免与其它子库的检出路径重叠),
       通过 copyfile 把根级脚本/配置落到工作区根。 -->
  <project name="meta.git" path=".meta" groups="meta">
    <copyfile src="README.md"             dest="README.md"/>
    <copyfile src="gitignore"             dest=".gitignore"/>
    <copyfile src="repo_metasar.bat"      dest="repo_metasar.bat"/>
    <copyfile src="run_gtest.bat"         dest="run_gtest.bat"/>
    <copyfile src="run_integrationTest.bat" dest="run_integrationTest.bat"/>
    <copyfile src="release_libs.bat"      dest="release_libs.bat"/>
    <copyfile src="misra.json"            dest="misra.json"/>
    <copyfile src="clang-format"          dest=".clang-format"/>
    <copyfile src="TestPlatform_UintTest_QEMU_Test.json" dest="TestPlatform_UintTest_QEMU_Test.json"/>
  </project>
</manifest>
