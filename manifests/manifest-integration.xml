<?xml version="1.0" encoding="UTF-8"?>
<!-- manifest-integration.xml — 基础(集成)工程师 (项目 Demo_Tc387):
     仅 Projects/*/Integration 源码可见; ASW/BSW/CDD/MCAL 全部以 *_Libs/.a 集成。
     ASW/CDD 库按项目下发对应子库。 -->
<manifest>
  <remote name="origin" fetch="ssh://git@example.com/autosar/"/>
  <default remote="origin" revision="main" sync-j="8"/>

  <!-- 集成代码源码可见 (Projects 含 Integration/Cfg/Ld/...) -->
  <project name="projects.git"   path="Projects"/>
  <project name="tools.git"      path="Tools"/>

  <!-- 共享库: 仅二进制 + 头文件 -->
  <project name="bsw-libs.git"   path="BSW_Libs"/>
  <project name="mcal-libs.git"  path="MCAL_Libs"/>
  <!-- 项目库: 仅本项目子库 -->
  <project name="asw-libs-Demo_Tc387.git" path="ASW_Libs/Demo_Tc387"/>
  <project name="cdd-libs-Demo_Tc387.git" path="CDD_Libs/Demo_Tc387"/>
</manifest>
