{
  "standard": "MISRA C:2012",
  "description": "OpenAutosar MISRA C:2012 静态检查配置 (供 QAC / cppcheck 使用)",
  "checkLevel": "required+advisory",
  "deviations": [
    {
      "rule": "21.6",
      "reason": "标准库 I/O 仅在测试桩 (Projects/*/Test/ut) 中使用",
      "scope": ["Projects/*/Test/ut/**"]
    },
    {
      "rule": "8.7",
      "reason": "供应商生成代码 (Gen/) 中存在跨翻译单元的外部链接对象",
      "scope": ["Projects/*/Gen/**"]
    }
  ],
  "suppressPaths": [
    "BSW/Os/**",
    "BSW/Com/**",
    "Tools/**",
    "Projects/*/Test/QAC/**"
  ],
  "include": [
    "ASW/**",
    "CDD/**",
    "Components/**",
    "MCAL/**"
  ]
}
